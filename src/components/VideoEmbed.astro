---
// =====================================================================
//  VideoEmbed — bloc vidéo sobre, responsive, réutilisable.
//  ---------------------------------------------------------------------
//  • Ne s'affiche QUE si `url` est renseignée (rien si vide).
//  • YouTube / Vimeo reconnus  → embed propre (youtube-nocookie, pas
//    d'autoplay, pas de tracking renforcé).
//  • URL non reconnue          → lien externe propre (nouvel onglet).
//  • N'invente aucune vidéo : tout vient des données de l'œuvre/page.
//
//  Usage (pages univers) :
//    <VideoEmbed url={maVideoUrl} title="Atelier" caption="…" />
// =====================================================================
import { getVideoEmbedUrl, type VideoProvider } from '../data/artworks';

interface Props {
  url?: string;
  provider?: VideoProvider;
  title?: string;
  caption?: string;
  class?: string;
}
const { url = '', provider, title, caption, class: extra = '' } = Astro.props;
const clean = url.trim();
const embed = getVideoEmbedUrl(clean, provider);
---
{clean && (
  <figure class={`mt-12 ${extra}`.trim()}>
    {embed ? (
      <div class="frame-gallery overflow-hidden p-[7px]">
        <div class="relative w-full overflow-hidden" style="aspect-ratio:16/9">
          <iframe
            src={embed}
            title={title || 'Vidéo'}
            loading="lazy"
            class="absolute inset-0 h-full w-full"
            referrerpolicy="strict-origin-when-cross-origin"
            allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    ) : (
      <a href={clean} target="_blank" rel="noopener noreferrer" class="btn btn-ghost">
        ▶ {title || 'Voir la vidéo'}
      </a>
    )}
    {caption && <figcaption class="mt-3 text-sm italic text-cendre">{caption}</figcaption>}
  </figure>
)}
