---
import { site, nav, contact, carnet } from '../data/site';
---
<header class="site-header" data-open="false">
  <div class="shell flex min-h-[5.5rem] items-center justify-between gap-6">
    <a href="/" class="group inline-flex flex-col leading-none" aria-label={`${site.artistName} — accueil`}>
      <span class="signature text-[1.7rem] text-encre">{site.artistName}</span>
      <span class="mt-1.5 text-[0.6rem] uppercase tracking-[0.26em] text-cendre">{site.role}</span>
    </a>

    <nav class="hidden lg:block" aria-label="Navigation principale">
      <ul class="flex items-center gap-7">
        {nav.map((item) => (
          <li><a href={item.href} class="nav-link">{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <button
      class="nav-toggle lg:hidden"
      type="button"
      aria-expanded="false"
      aria-controls="menu-atelier"
      aria-label="Ouvrir le carnet"
      data-nav-toggle
    >
      <span class="nav-toggle__lines" aria-hidden="true"><span></span><span></span></span>
      <span class="text-xs uppercase tracking-[0.2em]">Carnet</span>
    </button>
  </div>
  <div class="header-rule" aria-hidden="true"></div>

  {/* Le Carnet — menu éditorial (mobile/tablette) : une mini-page d'atelier */}
  <nav id="menu-atelier" class="atelier-menu" aria-label="Navigation" data-nav-menu>
    <p class="atelier-menu__title">{carnet.eyebrow}</p>
    <ul>
      {nav.map((item) => (
        <li>
          <a href={item.href} data-nav-close>
            <span class="atelier-menu__num" aria-hidden="true">{item.index}</span>
            <span class="atelier-menu__body">
              <span class="atelier-menu__label">{item.label}</span>
              <span class="atelier-menu__note">{item.note}</span>
            </span>
          </a>
        </li>
      ))}
    </ul>
    <div class="atelier-menu__foot">
      <p class="atelier-menu__intro">{carnet.intro}</p>
      <a href={`mailto:${contact.email}`} class="atelier-menu__mail" data-nav-close>{contact.email}</a>
    </div>
  </nav>
  <button class="nav-scrim" type="button" aria-hidden="true" tabindex="-1" data-nav-scrim></button>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgb(var(--c-paper));
  }
  /* Filet de haut de papier : encre + trace d'or (pas une barre premium). */
  .header-rule {
    height: 2px;
    background:
      linear-gradient(90deg, rgb(var(--c-encre) / 0.55), rgb(var(--c-encre) / 0.12) 38%, transparent 60%),
      linear-gradient(90deg, transparent 40%, rgb(var(--c-or) / calc(0.8 * var(--gold-trace))) 75%, transparent);
  }

  /* Bouton « Carnet » (mobile) — sobre, deux traits. */
  .nav-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    min-height: 2.75rem;
    padding: 0.4rem 0.5rem;
    color: rgb(var(--c-encre));
    background: transparent;
    border: 0;
  }
  .nav-toggle__lines { display: inline-flex; flex-direction: column; gap: 5px; width: 22px; }
  .nav-toggle__lines span { height: 1.5px; width: 100%; background: currentColor; transition: transform .3s ease, opacity .3s ease; }
  [aria-expanded="true"] .nav-toggle__lines span:nth-child(1) { transform: translateY(3.25px) rotate(6deg); }
  [aria-expanded="true"] .nav-toggle__lines span:nth-child(2) { transform: translateY(-3.25px) rotate(-6deg); }

  /* Carnet d'atelier (menu) — caché par défaut, visible en mobile/tablette */
  .atelier-menu { display: none; }
  .nav-scrim { display: none; }

  @media (max-width: 1023px) {
    .atelier-menu {
      display: block; /* annule le display:none global en mobile/tablette */
      position: absolute;
      left: 0;
      right: 0;
      top: 100%;
      background: rgb(var(--c-paper));
      border-bottom: 1px solid rgb(var(--c-encre) / 0.18);
      box-shadow: 0 18px 40px rgb(var(--c-encre) / 0.08);
      padding: 1.25rem clamp(1rem, 5vw, 2rem) 1.5rem;
      max-height: calc(100dvh - 5.5rem);
      overflow-y: auto;
      transform: translateY(-10px);
      opacity: 0;
      visibility: hidden;
      transition: opacity .25s ease, transform .25s ease, visibility .25s;
    }
    .atelier-menu__title {
      font-size: 0.62rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgb(var(--c-cendre));
      margin: 0 0 0.5rem;
    }
    .atelier-menu ul { list-style: none; margin: 0; padding: 0; }
    .atelier-menu li { border-top: 1px solid rgb(var(--c-encre) / 0.12); }
    .atelier-menu li:last-child { border-bottom: 1px solid rgb(var(--c-encre) / 0.12); }
    .atelier-menu li a {
      display: flex;
      align-items: flex-start;
      gap: 0.95rem;
      padding: 0.95rem 0.1rem;
      text-decoration: none;
      color: rgb(var(--c-encre));
    }
    .atelier-menu__num {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 0.9rem;
      line-height: 1.5;
      color: rgb(var(--c-or));
      min-width: 1.7rem;
    }
    .atelier-menu__body { display: flex; flex-direction: column; gap: 0.2rem; }
    .atelier-menu__label {
      font-family: var(--font-serif);
      font-size: 1.4rem;
      line-height: 1.05;
      color: rgb(var(--c-encre));
      transition: color .2s ease;
    }
    .atelier-menu__note {
      font-size: 0.85rem;
      line-height: 1.35;
      color: rgb(var(--c-cendre));
    }
    .atelier-menu li a:hover .atelier-menu__label,
    .atelier-menu li a:focus-visible .atelier-menu__label { color: rgb(var(--c-noir)); }

    .atelier-menu__foot {
      margin-top: 1.25rem;
      padding-top: 1.1rem;
      border-top: 1px solid rgb(var(--c-or) / calc(0.7 * var(--gold-trace)));
    }
    .atelier-menu__intro {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 1.02rem;
      line-height: 1.4;
      color: rgb(var(--c-encre));
      margin: 0 0 0.6rem;
      max-width: 34ch;
    }
    .atelier-menu__mail {
      display: inline-block;
      color: rgb(var(--c-encre));
      text-decoration: underline;
      text-decoration-color: rgb(var(--c-or) / 0.6);
      text-underline-offset: 0.22em;
      font-style: italic;
    }

    .site-header[data-open="true"] .atelier-menu {
      transform: translateY(0);
      opacity: 1;
      visibility: visible;
    }
    .site-header[data-open="true"] .nav-scrim {
      display: block;
      position: fixed;
      inset: 5.5rem 0 0;
      background: rgb(var(--c-noir) / 0.16);
      border: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .atelier-menu, .nav-toggle__lines span { transition: none; }
  }
</style>

<script>
  const header = document.querySelector('.site-header');
  const toggle = document.querySelector('[data-nav-toggle]');
  const scrim = document.querySelector('[data-nav-scrim]');

  const setOpen = (open: boolean) => {
    if (!header || !toggle) return;
    header.setAttribute('data-open', String(open));
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Fermer le carnet' : 'Ouvrir le carnet');
  };

  toggle?.addEventListener('click', () => setOpen(header?.getAttribute('data-open') !== 'true'));
  scrim?.addEventListener('click', () => setOpen(false));
  document.querySelectorAll('[data-nav-close]').forEach((link) =>
    link.addEventListener('click', () => setOpen(false)),
  );
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') setOpen(false); });
  const mq = window.matchMedia('(min-width: 1024px)');
  mq.addEventListener('change', (e) => { if (e.matches) setOpen(false); });
</script>
