---
import ArtworkPlaceholder from './ArtworkPlaceholder.astro';
import { type Artwork, statusLabel, priceLabel, getArtworkRequestUrl } from '../data/artworks';
import { theme } from '../data/theme';
import { shop } from '../data/shop';

interface Props {
  artwork: Artwork;
  /** 'feature' = mise en avant (cadre or, visuel plus présent). */
  variant?: 'default' | 'feature';
}
const { artwork, variant = 'default' } = Astro.props;
const a = artwork;
const isFeature = variant === 'feature';

// Pilotage par le thème (affichage) et par shop.ts (commerce doux).
const { showStatus, showTechnique } = theme.artworkCards;
const cta = shop.cta.artwork;
const priceText =
  a.status === 'sold'
    ? 'Vendue'
    : shop.showPrices
      ? priceLabel(a)
      : shop.defaultPriceLabel;

const statusColor: Record<string, string> = {
  available: 'text-encre',
  reserved: 'text-or',
  'on-request': 'text-cendre',
  sold: 'text-cendre',
};

const askHref = getArtworkRequestUrl(a);
const detailHref = `/oeuvres/${a.slug}`;
const metaParts = [a.technique, a.dimensions, a.year].filter(Boolean);
---
{/* Carte traitée comme un CARTEL d'exposition : cadre de galerie, nom en
    italique, filet or, statut discret — volontairement pas une « card » SaaS. */}
<article class="reveal group flex flex-col">
  <a
    href={detailHref}
    class={`frame-gallery relative block aspect-[4/5] w-full overflow-hidden p-[6px] ${isFeature ? 'border-or/45' : ''}`}
    aria-label={`Voir la fiche : ${a.title}`}
  >
    <div class="h-full w-full overflow-hidden">
      {a.image ? (
        <img
          src={a.image}
          alt={a.alt}
          loading="lazy"
          decoding="async"
          width="800"
          height="1000"
          sizes="(min-width: 1024px) 30vw, (min-width: 640px) 45vw, 90vw"
          class="h-full w-full object-cover transition-transform duration-700 ease-soft group-hover:scale-[1.02]"
        />
      ) : (
        <ArtworkPlaceholder />
      )}
    </div>
  </a>

  <figcaption class="mt-4 flex flex-1 flex-col">
    <div class="flex items-baseline justify-between gap-3">
      <h3 class={`font-serif italic leading-tight ${isFeature ? 'text-h2' : 'text-h3'}`}>
        <a href={detailHref} class="text-encre transition-colors hover:text-noir">{a.title}</a>
      </h3>
      {a.series && <span class="shrink-0 text-eyebrow uppercase tracking-[0.16em] text-cendre">{a.series}</span>}
    </div>

    {showTechnique && metaParts.length > 0 && (
      <p class="mt-1.5 text-xs uppercase tracking-[0.14em] text-cendre">{metaParts.join(' · ')}</p>
    )}

    {a.description && (
      <p class="mt-3 text-[0.95rem] leading-relaxed text-noir/80">{a.description}</p>
    )}

    <hr class="cartel-rule mt-4" />

    <div class="mt-3 flex items-center justify-between gap-4">
      {showStatus ? (
        <span class={`inline-flex items-center gap-1.5 text-[0.7rem] uppercase tracking-[0.18em] ${statusColor[a.status]}`}>
          <span class="status-dot" aria-hidden="true"></span>{statusLabel[a.status]}
        </span>
      ) : <span></span>}
      <span class={`font-serif text-base italic ${a.status === 'sold' ? 'text-cendre' : 'text-encre'}`}>{priceText}</span>
    </div>

    <div class="mt-3 flex flex-wrap items-center gap-x-5 gap-y-2 text-[0.92rem]">
      <a
        href={detailHref}
        class="font-medium text-encre underline decoration-cendre/40 decoration-1 underline-offset-4 transition-colors hover:decoration-encre"
      >
        Voir la fiche →
      </a>
      {a.status !== 'sold' && (
        <a
          href={askHref}
          class="font-medium text-encre underline decoration-or/60 decoration-1 underline-offset-4 transition-colors hover:decoration-or"
        >
          {cta} →
        </a>
      )}
    </div>
  </figcaption>
</article>
