      flex: none;
      color: rgb(var(--c-or));
      transition: transform 0.2s ease;
    }
    .cockpit-module[open] > .cockpit-summary .cockpit-chevron { transform: rotate(90deg); }
    /* Navigation interne accessible en permanence. */
