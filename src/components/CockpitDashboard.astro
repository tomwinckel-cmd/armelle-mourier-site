        <p class="sm:col-span-2 mt-2 text-eyebrow uppercase tracking-[0.16em] text-cendre">Vente / statut · publication</p>
        <label class="text-sm">Prix <span class="text-cendre">(vide = « Prix sur demande »)</span>
          <input id="p-price" type="text" placeholder="laisser vide" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none" />
        </label>
        <label class="text-sm">Publication web recommandée
          <input id="p-webpub" type="text" placeholder="version web compressée uniquement" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none" />
        </label>
        <label class="text-sm">Demande / acquéreur <span class="text-cendre">(optionnel)</span>
          <input id="p-request" type="text" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none" />
        </label>
        <label class="text-sm">Remise / logistique <span class="text-cendre">(optionnel)</span>
          <input id="p-logistics" type="text" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none" />
