  <script is:inline>
    // Tableau de bord : ouvrir le module replié ciblé par une ancre (clic / hash).
    (function () {
      function openTarget(hash) {
        if (!hash || hash.charAt(0) !== '#') return;
        var el;
        try { el = document.querySelector(hash); } catch (e) { return; }
        if (!el) return;
        var d = el.tagName === 'DETAILS' ? el : el.querySelector('details.cockpit-module');
        if (d) d.open = true;
      }
      document.querySelectorAll('a[href^="#"]').forEach(function (a) {
        a.addEventListener('click', function () { openTarget(a.getAttribute('href')); });
      });
      window.addEventListener('hashchange', function () { openTarget(location.hash); });
      if (location.hash) openTarget(location.hash);
    })();
  </script>

  <script is:inline>
    // Copier dans le presse-papier (sans API externe). Préparation seulement.
    function flash(btn, msg) {
      const old = btn.textContent;
      btn.textContent = msg;
      setTimeout(function () { btn.textContent = old; }, 1600);
    }
    function copyText(text, btn) {
      if (navigator.clipboard) { navigator.clipboard.writeText(text).then(function () { flash(btn, 'Copie OK'); }); }
      else { flash(btn, 'Selectionnez et copiez'); }
    }
    document.querySelectorAll('[data-copy]').forEach(function (btn) {
      btn.addEventListener('click', function () { copyText(btn.getAttribute('data-copy') || '', btn); });
    });

    // --- Assistant « Ajouter une œuvre » (guide + vérifie, NE SAUVEGARDE PAS) ---
    (function () {
      var form = document.getElementById('w-form');
      if (!form) return;
      var q = String.fromCharCode(0x2019);
      function v(id) { var el = document.getElementById(id); return el ? el.value.trim() : ''; }
      function c(id) { var el = document.getElementById(id); return !!(el && el.checked); }
      function slugify(s) { return s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, ''); }
      var statusFr = { available: 'Disponible', reserved: 'Réservée', sold: 'Vendue', 'on-request': 'Sur demande' };

      // Résumé propre à transmettre (format « NOUVELLE ŒUVRE — À AJOUTER »).
      function buildRecap() {
        return [
          'NOUVELLE ŒUVRE — À AJOUTER',
          '',
          'Titre : ' + v('w-title'),
          'Série : ' + v('w-series'),
          'Année : ' + v('w-year'),
          'Dimensions : ' + v('w-dimensions'),
          'Technique : ' + v('w-technique'),
          'Support : ' + v('w-support'),
          'Statut : ' + (statusFr[v('w-status')] || v('w-status')),
          'Description : ' + v('w-description'),
          'Image principale : ' + v('w-image'),
          'Images détails : ' + v('w-detail'),
          'Alt text : ' + v('w-alt'),
          'HD originale conservée : ' + (c('w-hd') ? 'oui (hors site)' : 'à conserver'),
          'Version web compressée : ' + (c('w-web') ? 'prête' : 'à préparer'),
          'Prix : ' + (v('w-price') || 'Prix sur demande'),
          'Validation humaine : à vérifier avant publication',
        ].join('\n');
      }
      function buildBlock() {
