  </style>

  <script is:inline>
    // Tableau de bord : ouvrir le module replié ciblé par une ancre (clic / hash).
    (function () {
      function openTarget(hash) {
        if (!hash || hash.charAt(0) !== '#') return;
        var el;
        try { el = document.querySelector(hash); } catch (e) { return; }
        if (!el) return;
        var d = el.tagName === 'DETAILS' ? el : el.querySelector('details.cockpit-module');
        if (d) d.open = true;
      }
      document.querySelectorAll('a[href^="#"]').forEach(function (a) {
        a.addEventListener('click', function () { openTarget(a.getAttribute('href')); });
      });
      window.addEventListener('hashchange', function () { openTarget(location.hash); });
      if (location.hash) openTarget(location.hash);
    })();
  </script>

  <script is:inline>
    // Copier dans le presse-papier (sans API externe). Préparation seulement.
    function flash(btn, msg) {
      const old = btn.textContent;
      btn.textContent = msg;
      setTimeout(function () { btn.textContent = old; }, 1600);
    }
    function copyText(text, btn) {
      if (navigator.clipboard) { navigator.clipboard.writeText(text).then(function () { flash(btn, 'Copie OK'); }); }
      else { flash(btn, 'Selectionnez et copiez'); }
    }
    document.querySelectorAll('[data-copy]').forEach(function (btn) {
      btn.addEventListener('click', function () { copyText(btn.getAttribute('data-copy') || '', btn); });
    });

    // --- Assistant « Ajouter une œuvre » (guide + vérifie, NE SAUVEGARDE PAS) ---
    (function () {
      var form = document.getElementById('w-form');
      if (!form) return;
      var q = String.fromCharCode(0x2019);
      function v(id) { var el = document.getElementById(id); return el ? el.value.trim() : ''; }
      function c(id) { var el = document.getElementById(id); return !!(el && el.checked); }
      function slugify(s) { return s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, ''); }
      var statusFr = { available: 'Disponible', reserved: 'Réservée', sold: 'Vendue', 'on-request': 'Sur demande' };

      // Résumé propre à transmettre (format « NOUVELLE ŒUVRE — À AJOUTER »).
      function buildRecap() {
        return [
          'NOUVELLE ŒUVRE — À AJOUTER',
          '',
          'Titre : ' + v('w-title'),
          'Série : ' + v('w-series'),
          'Année : ' + v('w-year'),
          'Dimensions : ' + v('w-dimensions'),
          'Technique : ' + v('w-technique'),
          'Support : ' + v('w-support'),
          'Statut : ' + (statusFr[v('w-status')] || v('w-status')),
          'Description : ' + v('w-description'),
          'Image principale : ' + v('w-image'),
          'Images détails : ' + v('w-detail'),
          'Alt text : ' + v('w-alt'),
          'HD originale conservée : ' + (c('w-hd') ? 'oui (hors site)' : 'à conserver'),
          'Version web compressée : ' + (c('w-web') ? 'prête' : 'à préparer'),
          'Prix : ' + (v('w-price') || 'Prix sur demande'),
          'Validation humaine : à vérifier avant publication',
        ].join('\n');
      }
      function buildBlock() {
        var title = v('w-title') || 'Sans titre';
        var slug = slugify(title) || 'oeuvre';
        var lines = ['{', "  id: '" + slug + "',", "  title: '" + title.split("'").join(q) + "',", "  slug: '" + slug + "',"];
        if (v('w-dimensions')) { lines.push("  dimensions: '" + v('w-dimensions') + "',"); }
        if (v('w-technique')) { lines.push("  technique: '" + v('w-technique') + "',"); }
        if (v('w-series')) { lines.push("  series: '" + v('w-series') + "',"); }
        if (v('w-year')) { lines.push("  year: '" + v('w-year') + "',"); }
        if (v('w-description')) { lines.push("  description: '" + v('w-description').split("'").join(q) + "',"); }
        lines.push("  image: '" + v('w-image') + "',");
        lines.push("  alt: '" + (v('w-alt') || title).split("'").join(q) + "',");
        lines.push("  status: '" + v('w-status') + "',");
        lines.push('},');
        return lines.join('\n');
      }
      function update() {
        // Complétude par étape (souple : on ne force pas les champs inconnus).
        var s1 = !!(v('w-title') && v('w-technique'));
        var s2 = !!(v('w-image') && v('w-alt') && v('w-description'));
        var s3 = c('w-human');
        var steps = (s1 ? 1 : 0) + (s2 ? 1 : 0) + (s3 ? 1 : 0);
        var done = { '1': s1, '2': s2, '3': s3 };
        var bar = document.getElementById('w-bar'); if (bar) bar.style.width = Math.round((steps / 3) * 100) + '%';
        var st = document.getElementById('w-step'); if (st) st.textContent = String(steps);
        document.querySelectorAll('[data-stepbadge]').forEach(function (el) {
          var on = done[el.getAttribute('data-stepbadge')];
          el.className = 'rounded-full px-3 py-1 text-xs ' + (on ? 'border border-or/60 bg-or/10 text-encre' : 'border border-cendre/30 text-cendre');
        });
        var labels = { 'w-title': 'titre', 'w-technique': 'technique', 'w-image': 'image', 'w-alt': 'alt text', 'w-description': 'description' };
        var miss = [];
        Object.keys(labels).forEach(function (k) { if (!v(k)) miss.push(labels[k]); });
        var mEl = document.getElementById('w-missing');
        if (mEl) mEl.textContent = 'À compléter : ' + (miss.length ? miss.join(', ') : 'rien — résumé prêt');
        var recapEl = document.getElementById('w-recap'); if (recapEl) recapEl.textContent = buildRecap();
      }
      form.addEventListener('input', update);
      update();
      var rc = document.querySelector('[data-recap-copy]'); if (rc) rc.addEventListener('click', function () { copyText(buildRecap(), rc); });
      var ac = document.querySelector('[data-art-copy]'); if (ac) ac.addEventListener('click', function () { copyText(buildBlock(), ac); });
    })();

    // --- Fiche œuvre + preuve de création (organise + prépare, NE SAUVEGARDE PAS) ---
    (function () {
      var form = document.getElementById('p-form');
      if (!form) return;
      function v(id) { var el = document.getElementById(id); return el ? el.value.trim() : ''; }
      function c(id) { var el = document.getElementById(id); return !!(el && el.checked); }
      function set(id, val) { var el = document.getElementById(id); if (el && val) el.value = val; }
      var statusFr = { available: 'Disponible', reserved: 'Réservée', sold: 'Vendue', 'on-request': 'Sur demande' };

      // Pré-remplir depuis une œuvre existante.
      var pick = document.getElementById('p-pick');
      if (pick) {
        pick.addEventListener('change', function () {
          var opt = pick.options[pick.selectedIndex];
          if (!opt || !opt.value) return;
          set('p-title', opt.getAttribute('data-title'));
          set('p-series', opt.getAttribute('data-series'));
          set('p-year', opt.getAttribute('data-year'));
          set('p-dimensions', opt.getAttribute('data-dimensions'));
          set('p-technique', opt.getAttribute('data-technique'));
          set('p-description', opt.getAttribute('data-description'));
          set('p-alt', opt.getAttribute('data-alt'));
          set('p-web', opt.getAttribute('data-image'));
          var st = document.getElementById('p-status');
          if (st && opt.getAttribute('data-status')) st.value = opt.getAttribute('data-status');
          update();
        });
      }

      function price() { return v('p-price') || 'Prix sur demande'; }
      function buildFiche() {
        return [
          'FICHE ŒUVRE — PREUVE DE CRÉATION',
          '',
          'Titre : ' + v('p-title'),
          'Série : ' + v('p-series'),
          'Année : ' + v('p-year'),
          'Dimensions : ' + v('p-dimensions'),
          'Technique : ' + v('p-technique'),
          'Support : ' + v('p-support'),
          'Description : ' + v('p-description'),
          'Date de création : ' + v('p-date'),
          'Lieu de création : ' + v('p-place'),
          'Images conservées :',
          '- HD originale : ' + v('p-hd'),
          '- Version web : ' + v('p-web'),
          '- Détails : ' + v('p-details'),
          'Statut : ' + (statusFr[v('p-status')] || v('p-status')),
          'Prix : ' + price(),
          'Publication web : ' + v('p-webpub'),
          'Alt text : ' + v('p-alt'),
          'Notes de protection : ' + v('p-protect'),
          'Historique d’exposition : ' + v('p-history'),
          'Demande / acquéreur : ' + v('p-request'),
          'Remise / logistique : ' + v('p-logistics'),
          'Réseaux sociaux : ' + v('p-social'),
          'Hashtags : ' + v('p-hashtags'),
          'Validation humaine : à vérifier avant publication',
        ].join('\n');
      }
      function buildChecklist() {
        var items = ['CHECKLIST DE PROTECTION — avant diffusion', ''];
        document.querySelectorAll('#p-checklist li span').forEach(function (el) {
          items.push('[ ] ' + el.textContent);
        });
        return items.join('\n');
      }

      var keys = ['p-title', 'p-series', 'p-year', 'p-dimensions', 'p-technique', 'p-support', 'p-description', 'p-date', 'p-place', 'p-hd', 'p-web', 'p-details', 'p-alt', 'p-webpub', 'p-protect', 'p-history', 'p-social', 'p-hashtags'];
      var checks = ['p-hd-kept', 'p-web-ready', 'p-proof-kept', 'p-exchanges', 'p-saleok'];
      function update() {
        var filled = 1, total = keys.length + checks.length + 1; // statut + prix par défaut
        keys.forEach(function (k) { if (v(k)) filled++; });
        checks.forEach(function (k) { if (c(k)) filled++; });
        var score = Math.round((filled / total) * 100);
        var bar = document.getElementById('p-bar'); if (bar) bar.style.width = score + '%';
        var sc = document.getElementById('p-score'); if (sc) sc.textContent = String(score);
        var lvl = document.getElementById('p-level');
        if (lvl) lvl.textContent = score >= 80 ? 'Prêt à valider' : (score >= 40 ? 'Presque prêt' : 'Brouillon');
        var got = {
          fiche: !!(v('p-title') && v('p-dimensions') && v('p-technique') && v('p-description')),
          images: !!(v('p-web') && v('p-alt') && c('p-web-ready')),
          protection: !!(v('p-date') && (c('p-proof-kept') || c('p-hd-kept'))),
          web: !!(v('p-webpub') && v('p-alt')),
          social: !!(v('p-social') && v('p-hashtags')),
          sale: c('p-saleok'),
        };
        document.querySelectorAll('[data-pbadge]').forEach(function (el) {
          var on = got[el.getAttribute('data-pbadge')];
          el.className = 'rounded-full px-3 py-1 text-xs ' + (on ? 'border border-or/60 bg-or/10 text-encre' : 'border border-cendre/30 text-cendre');
        });
        var recapEl = document.getElementById('p-recap'); if (recapEl) recapEl.textContent = buildFiche();
      }
      form.addEventListener('input', update);
      update();
      var fc = document.querySelector('[data-fiche-copy]'); if (fc) fc.addEventListener('click', function () { copyText(buildFiche(), fc); });
      var cc = document.querySelector('[data-checklist-copy]'); if (cc) cc.addEventListener('click', function () { copyText(buildChecklist(), cc); });
    })();

    // --- Après une demande d'acquisition (prépare brouillons, NE SAUVEGARDE PAS) ---
    (function () {
      var form = document.getElementById('t-form');
      if (!form) return;
      function v(id) { var el = document.getElementById(id); return el ? el.value.trim() : ''; }
      function c(id) { var el = document.getElementById(id); return !!(el && el.checked); }

      function buildInvoice() {
        return [
          'BROUILLON DE FACTURE — À VÉRIFIER',
          '',
          'Artiste : ' + (v('t-artist') || 'Armelle Mourier'),
          'Client : ' + v('t-client'),
          'Œuvre : ' + v('t-oeuvre'),
          'Dimensions : ' + v('t-dimensions'),
          'Technique : ' + v('t-technique'),
          'Prix : ' + (v('t-price') || 'à valider / prix sur demande'),
          'Date : ' + v('t-date'),
          'Numéro de facture : ' + (v('t-invnum') || 'à compléter'),
          'Mode de paiement : ' + (v('t-paymode') || 'à définir'),
          'Conditions : ' + v('t-conditions'),
          'Remise / livraison : ' + v('t-delmode'),
          'Notes : ' + v('t-notes'),
          'Validation humaine : obligatoire avant envoi',
        ].join('\n');
      }
      function buildLogistics() {
        return [
          'FICHE LOGISTIQUE — REMISE D’ŒUVRE',
          '',
          'Œuvre : ' + v('t-oeuvre'),
          'Client : ' + v('t-client'),
          'Mode de remise : ' + (v('t-delmode') || 'à définir'),
          '  (options : Retrait atelier · Livraison locale · Transporteur à définir)',
          'Adresse / lieu : ' + v('t-address'),
          'Date prévue : ' + v('t-deldate'),
          'Emballage : ' + v('t-packaging'),
          'État de l’œuvre avant départ : ' + v('t-state'),
          'Photos avant départ : ' + v('t-photos'),
          'Assurance : ' + v('t-insurance'),
          'Personne responsable : ' + v('t-responsible'),
          'Preuve de remise : ' + (c('t-proofok') ? 'prévue' : 'à prévoir'),
          'Signature / confirmation : ' + v('t-signature'),
          'Notes : ' + v('t-delnotes'),
        ].join('\n');
      }
      function buildMessage() {
        var sel = document.getElementById('t-msg');
        var opt = sel ? sel.options[sel.selectedIndex] : null;
        var body = opt ? (opt.getAttribute('data-body') || '') : '';
        var client = v('t-client') || '…';
        var oeuvre = v('t-oeuvre') || '…';
        var statut = v('t-status') || 'disponible';
        return body.split('{client}').join(client).split('{oeuvre}').join(oeuvre).split('{statut}').join(statut);
      }
      function buildDeliveryChecklist() {
        var items = ['CHECKLIST REMISE / LIVRAISON', ''];
        document.querySelectorAll('#t-delcheck li span').forEach(function (el) {
          items.push('[ ] ' + el.textContent);
        });
        return items.join('\n');
      }

      var keys = ['t-client', 't-email', 't-oeuvre', 't-dimensions', 't-technique', 't-price', 't-date', 't-conditions', 't-address', 't-deldate', 't-packaging', 't-state', 't-photos', 't-responsible', 't-signature'];
      var checks = ['t-priceok', 't-proofok', 't-archok'];
      function update() {
        var filled = 0, total = keys.length + checks.length;
        keys.forEach(function (k) { if (v(k)) filled++; });
        checks.forEach(function (k) { if (c(k)) filled++; });
        var score = Math.round((filled / total) * 100);
        var bar = document.getElementById('t-bar'); if (bar) bar.style.width = score + '%';
        var sc = document.getElementById('t-score'); if (sc) sc.textContent = String(score);
        var lvl = document.getElementById('t-level');
        if (lvl) lvl.textContent = score >= 80 ? 'Prêt à valider' : (score >= 40 ? 'Presque prêt' : 'Brouillon');
        var got = {
          request: !!(v('t-client') && v('t-email')),
          invoice: !!(v('t-oeuvre') && c('t-priceok')),
          logistics: !!(v('t-delmode') && v('t-deldate')),
          delivery: !!(v('t-photos') && v('t-state') && c('t-proofok')),
          archive: c('t-archok'),
        };
        document.querySelectorAll('[data-tbadge]').forEach(function (el) {
          var on = got[el.getAttribute('data-tbadge')];
          el.className = 'rounded-full px-3 py-1 text-xs ' + (on ? 'border border-or/60 bg-or/10 text-encre' : 'border border-cendre/30 text-cendre');
        });
        var iv = document.getElementById('t-invoice'); if (iv) iv.textContent = buildInvoice();
        var lg = document.getElementById('t-logistics'); if (lg) lg.textContent = buildLogistics();
        var mo = document.getElementById('t-msgout'); if (mo) mo.textContent = buildMessage();
      }
      form.addEventListener('input', update);
      var msg = document.getElementById('t-msg'); if (msg) msg.addEventListener('change', update);
      update();
      var ib = document.querySelector('[data-invoice-copy]'); if (ib) ib.addEventListener('click', function () { copyText(buildInvoice(), ib); });
      var lb = document.querySelector('[data-logistics-copy]'); if (lb) lb.addEventListener('click', function () { copyText(buildLogistics(), lb); });
      var mb = document.querySelector('[data-msg-copy]'); if (mb) mb.addEventListener('click', function () { copyText(buildMessage(), mb); });
      var db = document.querySelector('[data-deliverychecklist-copy]'); if (db) db.addEventListener('click', function () { copyText(buildDeliveryChecklist(), db); });
    })();

    // --- Catalogue / dossier collectionneur (prépare un brouillon, NE SAUVEGARDE PAS) ---
    (function () {
      var form = document.getElementById('c-form');
      if (!form) return;
      function v(id) { var el = document.getElementById(id); return el ? el.value.trim() : ''; }
      function selected() {
        var out = [];
        document.querySelectorAll('.c-art').forEach(function (el) { if (el.checked) out.push(el); });
        return out;
      }
      function buildList() {
        var arts = selected();
        if (!arts.length) return '(aucune œuvre sélectionnée)';
        var lines = [];
        arts.forEach(function (el, i) {
          lines.push(String(i + 1) + '.');
          lines.push('Titre : ' + (el.getAttribute('data-title') || ''));
          lines.push('Série : ' + (el.getAttribute('data-series') || ''));
          lines.push('Dimensions : ' + (el.getAttribute('data-dimensions') || ''));
          lines.push('Technique : ' + (el.getAttribute('data-technique') || ''));
          lines.push('Statut : ' + (el.getAttribute('data-status') || ''));
          lines.push('Prix : ' + (el.getAttribute('data-price') || 'Prix sur demande'));
          lines.push('Lien fiche : /oeuvres/' + (el.getAttribute('data-slug') || ''));
          lines.push('Notes : ');
          lines.push('');
        });
        return lines.join('\n').replace(/\n+$/, '');
      }
      function buildDossier() {
        return [
          'DOSSIER COLLECTIONNEUR — BROUILLON',
          '',
          'Type : ' + v('c-type'),
          'Destinataire : ' + v('c-dest'),
          'Contexte : ' + v('c-context'),
          'Date : ' + v('c-date'),
          'Message d’introduction : ' + v('c-intro'),
          '',
          'Œuvres sélectionnées :',
          buildList(),
          '',
          'Conditions :',
          (v('c-conditions') || '- Acquisition en lien direct avec l’artiste.'),
          '',
          'Notes : ' + v('c-notes'),
          'Contact :',
          'Email : ' + v('c-email'),
          '',
          'Validation humaine : à vérifier avant envoi',
        ].join('\n');
      }
      function buildMessage() {
        var sel = document.getElementById('c-msg');
        var opt = sel ? sel.options[sel.selectedIndex] : null;
        var body = opt ? (opt.getAttribute('data-body') || '') : '';
        var dest = v('c-dest') || '…';
        return body.split('{destinataire}').join(dest);
      }
      function update() {
        var count = selected().length;
        var cc = document.getElementById('c-count'); if (cc) cc.textContent = String(count);
        var pct = Math.min(100, count * 20);
        var bar = document.getElementById('c-bar'); if (bar) bar.style.width = pct + '%';
        var lvl = document.getElementById('c-level');
        if (lvl) lvl.textContent = (count >= 3 ? 'Prêt à valider' : (count >= 1 ? 'En cours' : 'Brouillon'));
        var got = {
          selection: count >= 1,
          status: count >= 1,
          images: !!v('c-conditions'),
          message: !!v('c-intro'),
          ready: !!(count >= 1 && v('c-dest') && v('c-email') && v('c-intro')),
        };
        document.querySelectorAll('[data-cbadge]').forEach(function (el) {
          var on = got[el.getAttribute('data-cbadge')];
          el.className = 'rounded-full px-3 py-1 text-xs ' + (on ? 'border border-or/60 bg-or/10 text-encre' : 'border border-cendre/30 text-cendre');
        });
        var lo = document.getElementById('c-list'); if (lo) lo.textContent = buildList();
        var doo = document.getElementById('c-dossier'); if (doo) doo.textContent = buildDossier();
        var mo = document.getElementById('c-msgout'); if (mo) mo.textContent = buildMessage();
      }
      form.addEventListener('input', update);
      var msg = document.getElementById('c-msg'); if (msg) msg.addEventListener('change', update);
      update();
      var lc = document.querySelector('[data-list-copy]'); if (lc) lc.addEventListener('click', function () { copyText(buildList(), lc); });
      var dc = document.querySelector('[data-dossier-copy]'); if (dc) dc.addEventListener('click', function () { copyText(buildDossier(), dc); });
      var mc = document.querySelector('[data-cmsg-copy]'); if (mc) mc.addEventListener('click', function () { copyText(buildMessage(), mc); });
    })();

    // --- Préparer une publication (copier-coller, AUCUNE API, AUCUNE publication auto) ---
    (function () {
      var form = document.getElementById('sp-form');
      if (!form) return;
      function v(id) { var el = document.getElementById(id); return el ? el.value.trim() : ''; }
      function c(id) { var el = document.getElementById(id); return !!(el && el.checked); }
      var typeSel = document.getElementById('sp-type');
      var fmtSel = document.getElementById('sp-format');
      var fmtLabel = {}; // value -> texte lisible (depuis les options du select format)
      if (fmtSel) { Array.prototype.forEach.call(fmtSel.options, function (o) { fmtLabel[o.value] = o.textContent; }); }
      var typeLabel = {};
      if (typeSel) { Array.prototype.forEach.call(typeSel.options, function (o) { typeLabel[o.value] = o.textContent; }); }

      // Pré-remplir légende / format / hashtags depuis le type choisi.
      function applyType() {
        if (!typeSel) return;
        var opt = typeSel.options[typeSel.selectedIndex];
        if (!opt) return;
        var cap = document.getElementById('sp-caption'); if (cap) cap.value = opt.getAttribute('data-caption') || '';
        if (fmtSel && opt.getAttribute('data-format')) fmtSel.value = opt.getAttribute('data-format');
        var tags = document.getElementById('sp-hashtags'); if (tags) tags.value = opt.getAttribute('data-hashtags') || '';
        update();
      }

      function caption() { return v('sp-caption'); }
      function hashtags() { return v('sp-hashtags'); }
      function buildRecap() {
        return [
          'PUBLICATION À PRÉPARER',
          '',
          'Type : ' + (typeSel ? (typeLabel[typeSel.value] || typeSel.value) : ''),
          'Format recommandé : ' + (fmtSel ? (fmtLabel[fmtSel.value] || fmtSel.value) : ''),
          'Œuvre / sujet : ' + v('sp-subject'),
          'Légende : ' + caption(),
          'Hashtags : ' + hashtags(),
          'Image à utiliser : ' + v('sp-image'),
          'Version web compressée : ' + (c('sp-web') ? 'prête' : 'à préparer'),
          'Ton : ' + v('sp-tone'),
          'Validation humaine : à vérifier avant publication',
          'À publier manuellement sur : Instagram',
        ].join('\n');
      }
      function update() {
        var got = {
          legende: !!caption(),
          hashtags: !!hashtags(),
          image: !!(v('sp-image') && c('sp-web')),
          statut: c('sp-status'),
          ready: !!(caption() && hashtags() && c('sp-human')),
        };
        document.querySelectorAll('[data-spbadge]').forEach(function (el) {
          var on = got[el.getAttribute('data-spbadge')];
          el.className = 'rounded-full px-3 py-1 text-xs ' + (on ? 'border border-or/60 bg-or/10 text-encre' : 'border border-cendre/30 text-cendre');
        });
        var lvl = document.getElementById('sp-level');
        if (lvl) lvl.textContent = got.ready ? 'Prête à copier' : (got.legende && got.hashtags ? 'Presque prête' : 'À préparer');
        var rec = document.getElementById('sp-recap'); if (rec) rec.textContent = buildRecap();
      }
      if (typeSel) typeSel.addEventListener('change', applyType);
      form.addEventListener('input', update);
      applyType();
      document.querySelectorAll('[data-sp-caption-copy]').forEach(function (b) { b.addEventListener('click', function () { copyText(caption(), b); }); });
      document.querySelectorAll('[data-sp-hashtags-copy]').forEach(function (b) { b.addEventListener('click', function () { copyText(hashtags(), b); }); });
      var rc = document.querySelector('[data-sp-recap-copy]'); if (rc) rc.addEventListener('click', function () { copyText(buildRecap(), rc); });
    })();
  </script>
