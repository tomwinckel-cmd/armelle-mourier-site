      function mode() {
        var r = document.querySelector('input[name="vi-mode"]:checked');
        return r ? { label: r.getAttribute('data-label') || '', intention: r.getAttribute('data-intention') || '' } : { label: '', intention: '' };
      }
      function reinforce() {
        var out = [];
        if (parseInt(v('vi-blue') || '50', 10) >= 60) out.push('bleu');
        if (parseInt(v('vi-ochre') || '50', 10) >= 60) out.push('ocre');
        return out.join(', ') || '—';
      }
      function soften() {
        var out = [];
        if (parseInt(v('vi-blue') || '50', 10) <= 40) out.push('bleu');
        if (parseInt(v('vi-ochre') || '50', 10) <= 40) out.push('ocre');
        return out.join(', ') || '—';
      }
      function buildRecap() {
        var m = mode();
        return [
          'AMBIANCE VISUELLE — DEMANDE DE MODIFICATION',
          '',
          'Mode choisi : ' + m.label,
          'Objectif : ' + m.intention + (v('vi-tone') ? ' · ton : ' + v('vi-tone') : ''),
          'Couleurs à renforcer : ' + reinforce(),
          'Couleurs à adoucir : ' + soften(),
          'Texture : ' + (v('vi-texture') || 'à préciser'),
          'Cartes : ' + (v('vi-cards') || 'à préciser'),
          'Boutons : ' + (v('vi-buttons') || 'à préciser'),
          'Commentaire artiste : ' + v('vi-comment'),
          'Validation humaine : à vérifier avant modification du site',
        ].join('\n');
      }
      function update() {
        var bv = document.getElementById('vi-blue-val'); if (bv) bv.textContent = v('vi-blue') || '50';
        var ov = document.getElementById('vi-ochre-val'); if (ov) ov.textContent = v('vi-ochre') || '50';
        var got = {
          mode: !!mode().label,
          colors: !!(reinforce() !== '—' || soften() !== '—'),
          texture: !!v('vi-texture'),
          cards: !!v('vi-cards'),
          ready: !!(mode().label && c('vi-human')),
        };
        document.querySelectorAll('[data-vibadge]').forEach(function (el) {
          var on = got[el.getAttribute('data-vibadge')];
          el.className = 'rounded-full px-3 py-1 text-xs ' + (on ? 'border border-or/60 bg-or/10 text-encre' : 'border border-cendre/30 text-cendre');
        });
        var lvl = document.getElementById('vi-level');
        if (lvl) lvl.textContent = got.ready ? 'Prête à valider' : (got.mode ? 'En cours' : 'À préparer');
        var rec = document.getElementById('vi-recap'); if (rec) rec.textContent = buildRecap();
      }
      form.addEventListener('input', update);
      form.addEventListener('change', update);
      update();
      var vc = document.querySelector('[data-vi-copy]'); if (vc) vc.addEventListener('click', function () { copyText(buildRecap(), vc); });
    })();
  </script>
