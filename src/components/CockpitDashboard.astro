          <label class="flex items-center gap-2"><input id="p-proof-kept" type="checkbox" /> Œuvre importante : preuve datée envisagée (e-Soleau / autre)</label>
          <label class="flex items-center gap-2"><input id="p-exchanges" type="checkbox" /> Échanges importants archivés</label>
          <label class="flex items-center gap-2"><input id="p-saleok" type="checkbox" /> Vente douce vérifiée — « Prix sur demande » si rien n’est validé</label>
        </fieldset>
      </form>

      <!-- Gamification douce -->
      <div class="mt-6 frame-gallery p-5">
