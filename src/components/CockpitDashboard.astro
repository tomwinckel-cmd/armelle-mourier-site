  <style>
    /* En-tête repliable des modules lourds (details/summary natif, accessible). */
    .cockpit-summary {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
      cursor: pointer;
      list-style: none;
