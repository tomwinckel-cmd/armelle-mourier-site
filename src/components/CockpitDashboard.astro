        </label>
        <label class="text-sm">Statut de l’œuvre
          <select id="t-status" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none">
            <option value="disponible">Disponible</option>
            <option value="réservée">Réservée</option>
            <option value="sur demande">Sur demande</option>
