---
import { artworks, statusLabel, isForSale, hasImage, priceLabel, type ArtworkStatus } from '../data/artworks';
import { shop } from '../data/shop';
import { socialPublishing } from '../data/social';
import { cockpit } from '../data/cockpit';
import { theme } from '../data/theme';
import { splitExhibitions } from '../data/exhibitions';
import { operations, operationsPrinciple, operationActivation, type OperationStatus } from '../data/operations';
import { addArtworkSteps } from '../data/artworkWorkflow';
import { visualModes } from '../data/theme';
import { webPublicationTips, protectionChecklist, proofBadges } from '../data/proof';
import { messageTemplates, transactionBadges, requestTypes, requestResponses, requestStatuses, requestBadges } from '../data/transactionWorkflow';
import { catalogTypes, catalogChecklist, catalogMessages, catalogBadges } from '../data/catalogWorkflow';

// ---- Données (lecture seule) ----
const totalArtworks = artworks.length;
const withImage = artworks.filter(hasImage).length;
const statuses: ArtworkStatus[] = ['available', 'reserved', 'sold', 'on-request'];
const byStatus = Object.fromEntries(
  statuses.map((s) => [s, artworks.filter((a) => a.status === s)]),
) as Record<ArtworkStatus, typeof artworks>;
const { upcoming, past } = splitExhibitions();

// Champs requis pour ajouter une œuvre (depuis le schéma cockpit).

// Zones éditoriales pilotables et où elles vivent aujourd'hui.
const editorialZones = [
  { label: 'Accueil (accroche + récit)', file: 'src/content/pages.ts · src/data/site.ts' },
  { label: 'Biographie', file: 'src/content/bio.ts' },
  { label: 'Démarche', file: 'src/content/bio.ts' },
  { label: 'Bleu Cendres', file: 'src/content/bio.ts' },
  { label: 'Expositions', file: 'src/data/exhibitions.ts' },
  { label: 'Contact (e-mail, sujets)', file: 'src/data/site.ts · src/data/shop.ts' },
];

// Palette actuelle (depuis theme.ts) pour l'aperçu « Ambiance visuelle ».
const palette = [
  { key: 'paper', label: 'Papier (fond)', hex: theme.colors.paper },
  { key: 'paperRaw', label: 'Papier brut', hex: theme.colors.paperRaw },
  { key: 'bluePigment', label: 'Bleu pigment', hex: theme.colors.bluePigment },
  { key: 'blueDeep', label: 'Bleu nuit', hex: theme.colors.blueDeep },
  { key: 'blueWash', label: 'Bleu aquatique', hex: theme.colors.blueWash },
  { key: 'ochreGold', label: 'Ocre / or', hex: theme.colors.ochreGold },
  { key: 'inkBlack', label: 'Noir encre', hex: theme.colors.inkBlack },
  { key: 'ashBlue', label: 'Cendre', hex: theme.colors.ashBlue },
];

// Navigation interne du tableau de bord (libellés courts, scannables).
const dashboardNav = [
  { id: 'apercu', label: 'Vue d’ensemble' },
  { id: 'intake', label: 'Ajouter une œuvre' },
  { id: 'proof', label: 'Protéger' },
  { id: 'social', label: 'Publication' },
  { id: 'catalog', label: 'Catalogue' },
  { id: 'respond', label: 'Répondre' },
  { id: 'transaction', label: 'Facture & remise' },
  { id: 'ambiance', label: 'Ambiance' },
  { id: 'etapes', label: 'Roadmap' },
];

// Actions rapides : « Que veux-tu faire maintenant ? » → ancres internes.
type ActionState = 'active' | 'prepared' | 'future';
const quickActions: { href: string; label: string; hint: string; state: ActionState }[] = [
  { href: '#intake', label: 'Ajouter une œuvre', hint: 'Préparer une fiche sans erreur', state: 'active' },
  { href: '#proof', label: 'Protéger une œuvre', hint: 'Préparer un dossier de preuve', state: 'active' },
  { href: '#social', label: 'Préparer une publication', hint: 'Légende à copier-coller', state: 'active' },
  { href: '#catalog', label: 'Préparer un catalogue', hint: 'Dossier à transmettre', state: 'active' },
  { href: '#respond', label: 'Répondre à une demande', hint: 'Réponse claire à copier', state: 'active' },
  { href: '#transaction', label: 'Facture & remise', hint: 'Brouillons à copier', state: 'active' },
  { href: '#ambiance', label: 'Ajuster l’ambiance visuelle', hint: 'Préparer une demande', state: 'prepared' },
];
// Libellés d'état (ton adulte, pas de jeu vidéo).
const actionStateLabel: Record<ActionState, string> = { active: 'actif', prepared: 'préparation', future: 'bientôt' };
const actionStateColor: Record<ActionState, string> = { active: 'text-encre', prepared: 'text-or', future: 'text-cendre' };

// Badges de progression (sobres) — ce qui est déjà en place / assisté.
const cockpitBadges: { label: string; done: boolean }[] = [
  { label: 'Site public prêt', done: true },
  { label: 'Galerie prête', done: true },
  { label: 'Vente douce prête', done: true },
  { label: 'Protection assistée', done: true },
  { label: 'Catalogue assisté', done: true },
  { label: 'Facture brouillon', done: true },
  { label: 'Logistique assistée', done: true },
  { label: 'Réseaux sociaux préparés', done: true },
];

// Statut des modules du cockpit (vue d’ensemble, ton adulte, pas d’infantilisation).
type ModuleState = 'prototype' | 'preparation' | 'future';
const cockpitModuleStatus: { label: string; state: ModuleState; href: string }[] = [
  { label: 'Ajouter une œuvre', state: 'prototype', href: '#intake' },
  { label: 'Fiche œuvre + preuve', state: 'prototype', href: '#proof' },
  { label: 'Vente douce', state: 'prototype', href: '#disponibilites' },
  { label: 'Réseaux sociaux', state: 'prototype', href: '#social' },
  { label: 'Catalogue', state: 'prototype', href: '#catalog' },
  { label: 'Facture brouillon', state: 'prototype', href: '#transaction' },
  { label: 'Remise / livraison', state: 'prototype', href: '#transaction' },
  { label: 'Ambiance visuelle', state: 'preparation', href: '#ambiance' },
  { label: 'Édition réelle (CMS)', state: 'future', href: '#etapes' },
  { label: 'Dépôt d’images', state: 'future', href: '#etapes' },
  { label: 'Authentification', state: 'future', href: '#etapes' },
];
const moduleStateLabel: Record<ModuleState, string> = {
  prototype: 'Modules actifs',
  preparation: 'En préparation',
  future: 'Prochaines activations',
};
const moduleStateOrder: ModuleState[] = ['prototype', 'preparation', 'future'];
const modulesByState = Object.fromEntries(
  moduleStateOrder.map((s) => [s, cockpitModuleStatus.filter((m) => m.state === s)]),
) as Record<ModuleState, typeof cockpitModuleStatus>;

// Titres orientés action pour les cartes du centre opérationnel.
const opCardTitle: Record<string, string> = {
  ip: 'Protéger une œuvre',
  social: 'Préparer une publication',
  'soft-sale': 'Répondre à une demande',
  invoicing: 'Préparer une facture brouillon',
  logistics: 'Organiser la remise ou livraison',
  catalog: 'Préparer un catalogue',
};
const opStatusLabel: Record<OperationStatus, string> = {
  planned: 'à venir',
  prototype: 'prototype',
  active: 'actif',
};
const opStatusColor: Record<OperationStatus, string> = {
  planned: 'text-cendre',
  prototype: 'text-or',
  active: 'text-encre',
};
const opCards = operations.filter((o) => o.id !== 'human-relation');

const statusChipClass: Record<ArtworkStatus, string> = {
  available: 'text-encre',
  reserved: 'text-or',
  sold: 'text-cendre',
  'on-request': 'text-cendre',
};
---
  <section class="shell pb-section pt-10 sm:pt-14">
    <p class="eyebrow mb-3">Outil interne · non public</p>
    <h1 class="signature text-display text-encre">Cockpit artiste</h1>
    <p class="mt-3 max-w-prose font-serif text-xl italic leading-snug text-encre">
      Centre opérationnel pour préparer, protéger et organiser les œuvres.
    </p>
    <p class="mt-4 max-w-prose rounded-card border border-or/40 bg-or/5 px-5 py-3 text-noir/85">
      Choisis une action, <strong>prépare</strong> les informations, <strong>copie</strong> le
      résultat, puis <strong>valide humainement</strong>.
    </p>

    <!-- GARDE-FOUS : ce que le cockpit fait / ne fait pas encore -->
    <div class="mt-5 grid max-w-3xl gap-4 sm:grid-cols-2">
      <div class="frame-gallery p-5">
        <p class="text-eyebrow uppercase tracking-[0.16em] text-or">Ce que le cockpit fait</p>
        <ul class="mt-2 space-y-1 text-sm text-noir/80">
          <li>· Prépare les contenus</li>
          <li>· Vérifie (garde-fous, checklists)</li>
          <li>· Structure (fiches, dossiers)</li>
          <li>· Copie (à coller où tu veux)</li>
        </ul>
      </div>
      <div class="frame-gallery p-5">
        <p class="text-eyebrow uppercase tracking-[0.16em] text-cendre">Ce qu’il ne fait pas encore</p>
        <ul class="mt-2 space-y-1 text-sm text-noir/70">
          <li>· Sauvegarder</li>
          <li>· Publier / envoyer</li>
          <li>· Encaisser</li>
          <li>· Remplacer un conseil professionnel</li>
        </ul>
      </div>
    </div>
    <p class="mt-3 text-sm text-cendre">Aucune sauvegarde automatique · validation humaine à chaque étape.</p>

    <!-- ÉCRAN D'ACCUEIL OPÉRATIONNEL : « Que veux-tu faire maintenant ? » -->
    <section aria-labelledby="quick-actions-title" class="mt-10">
      <h2 id="quick-actions-title" class="text-h2 font-serif text-encre">Que veux-tu faire maintenant ?</h2>
      <p class="mt-1 text-sm text-cendre">Choisis une action — chaque carte ouvre le module correspondant.</p>
      <div class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {quickActions.map((a) => (
          <a href={a.href} class="quick-action frame-gallery flex flex-col gap-1.5 p-5 transition-colors hover:border-or/60">
            <span class="flex items-baseline justify-between gap-2">
              <span class="font-serif text-lg italic leading-tight text-encre">{a.label}</span>
              <span class={`shrink-0 text-eyebrow uppercase tracking-[0.14em] ${actionStateColor[a.state]}`}>{actionStateLabel[a.state]}</span>
            </span>
            <span class="text-sm text-cendre">{a.hint}</span>
            <span class="mt-1 text-sm font-semibold text-encre underline decoration-or/50 decoration-1 underline-offset-4">Ouvrir →</span>
          </a>
        ))}
      </div>
    </section>

    <!-- NAVIGATION INTERNE (sticky, libellés courts) -->
    <nav aria-label="Navigation du cockpit" class="cockpit-nav mt-8 flex flex-wrap gap-2 border-y border-cendre/20 py-3 text-sm">
      {dashboardNav.map((s) => (
        <a href={`#${s.id}`} class="rounded-full border border-cendre/30 px-3 py-1 font-semibold text-encre transition-colors hover:border-or/60 hover:text-or">{s.label}</a>
      ))}
    </nav>

    <!-- 1 — VUE D'ENSEMBLE -->
    <section id="apercu" class="scroll-mt-28">
      <h2 class="mt-14 text-h2 font-serif text-encre">Vue d’ensemble</h2>
      <div class="rule-gold mt-4" aria-hidden="true"></div>
      <p class="mt-4 max-w-prose font-serif text-lg italic text-encre">{cockpit.philosophy}</p>
      <dl class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-4">
        <div class="frame-gallery p-4"><dt class="text-eyebrow uppercase tracking-[0.16em] text-cendre">Œuvres</dt><dd class="mt-1 font-serif text-3xl text-encre">{totalArtworks}</dd></div>
        <div class="frame-gallery p-4"><dt class="text-eyebrow uppercase tracking-[0.16em] text-cendre">Disponibles</dt><dd class="mt-1 font-serif text-3xl text-encre">{artworks.filter(isForSale).length}</dd></div>
        <div class="frame-gallery p-4"><dt class="text-eyebrow uppercase tracking-[0.16em] text-cendre">Avec photo</dt><dd class="mt-1 font-serif text-3xl text-encre">{withImage}/{totalArtworks}</dd></div>
        <div class="frame-gallery p-4"><dt class="text-eyebrow uppercase tracking-[0.16em] text-cendre">Expositions</dt><dd class="mt-1 font-serif text-3xl text-encre">{upcoming.length + past.length}</dd></div>
      </dl>
      <ul class="mt-6 grid gap-2 sm:grid-cols-2">
        {cockpit.modules.map((m) => (
          <li class="border-l-2 border-cendre/30 pl-4">
            <span class="text-encre">{m.label}</span>
            <span class="block text-sm text-cendre">{m.description}</span>
          </li>
        ))}
      </ul>

      <!-- PROGRESSION DU COCKPIT (sobre, ton adulte) -->
      <div class="mt-8 rounded-card border border-or/30 bg-or/5 px-5 py-5">
        <p class="text-eyebrow uppercase tracking-[0.16em] text-or">Progression du cockpit</p>
        <div class="mt-4 grid gap-5 sm:grid-cols-3">
          {moduleStateOrder.map((state) => (
            <div>
              <p class="text-sm font-semibold text-encre">{moduleStateLabel[state]} <span class="text-cendre">({modulesByState[state].length})</span></p>
              <ul class="mt-2 space-y-1 text-sm">
                {modulesByState[state].map((m) => (
                  <li>
                    <a href={m.href} class="link-quiet text-noir/80">{m.label}</a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
        <ul class="mt-5 flex flex-wrap gap-2 border-t border-or/20 pt-4">
          {cockpitBadges.map((b) => (
            <li class={`rounded-full px-3 py-1 text-xs ${b.done ? 'border border-or/55 bg-or/10 text-encre' : 'border border-cendre/30 text-cendre'}`}>
              {b.done ? '✓ ' : ''}{b.label}
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- CENTRE OPÉRATIONNEL -->
    <section id="operations" class="scroll-mt-28">
      <h2 class="mt-16 text-h2 font-serif text-encre">Centre opérationnel</h2>
      <div class="rule-gold mt-4" aria-hidden="true"></div>
      <p class="mt-4 max-w-prose text-noir/80">
        Le cockpit simplifie le quotidien : <strong>préparer, organiser, protéger</strong> —
        pour qu’Armelle se concentre sur son art. Certaines fonctions sont <em>futures</em>.
      </p>
      <p class="mt-2 max-w-prose text-sm italic text-cendre">{operationsPrinciple}</p>

      <div class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {opCards.map((o) => (
          <article class="frame-gallery p-5">
            <div class="flex items-baseline justify-between gap-3">
              <h3 class="font-serif text-lg italic text-encre">{opCardTitle[o.id] ?? o.label}</h3>
              <span class={`text-eyebrow uppercase tracking-[0.14em] ${opStatusColor[o.status]}`}>{opStatusLabel[o.status]}</span>
            </div>
            <p class="mt-2 text-sm text-noir/75">{o.description}</p>
            <ul class="mt-2 space-y-0.5 text-sm text-noir/70">
              {o.actions.slice(0, 3).map((a) => <li>· {a}</li>)}
            </ul>
            {operationActivation[o.id] && (
              <p class="mt-3 border-t border-cendre/20 pt-2 text-xs text-cendre">
                Nécessite : {operationActivation[o.id].requirement}
              </p>
            )}
          </article>
        ))}
      </div>

      <p class="mt-6 max-w-prose rounded-card border border-cendre/30 bg-brume/40 px-5 py-4 text-sm text-noir/80">
        <strong>Aucune action sensible ne sera automatisée sans validation humaine.</strong>
        Armelle décide · Tom valide · Claude Code exécute. L’objectif est de laisser l’artiste
        se concentrer sur son art. Voir aussi <code class="text-cendre">docs/ip-protection-artist.md</code>.
      </p>
    </section>

    <!-- 2 — ŒUVRES -->
    <section id="oeuvres" class="scroll-mt-28">
      <h2 class="mt-16 text-h2 font-serif text-encre">Œuvres</h2>
      <div class="rule-gold mt-4" aria-hidden="true"></div>
      <p class="mt-4 text-noir/75">{totalArtworks} œuvres au catalogue · source : <code class="text-cendre">src/data/artworks.ts</code></p>

      <ul class="mt-6 divide-y divide-cendre/20 border-y border-cendre/20">
        {artworks.map((a) => (
          <li class="flex items-center gap-4 py-3">
            <span class="flex h-12 w-10 shrink-0 items-center justify-center overflow-hidden border border-cendre/25 bg-paper">
              {a.image ? (
                <img src={a.image} alt={a.alt} class="h-full w-full object-cover" loading="lazy" width="40" height="48" />
              ) : (
                <span class="font-serif text-base italic text-cendre" aria-hidden="true">{a.title.charAt(0)}</span>
              )}
            </span>
            <span class="min-w-0 flex-1">
              <span class="block truncate font-serif italic text-encre">{a.title}</span>
              <span class="block truncate text-xs text-cendre">{[a.series, a.technique].filter(Boolean).join(' · ')}</span>
            </span>
            <span class={`shrink-0 text-[0.7rem] uppercase tracking-[0.16em] ${statusChipClass[a.status]}`}>{statusLabel[a.status]}</span>
            <span class={`hidden shrink-0 text-xs sm:inline ${hasImage(a) ? 'text-encre' : 'text-cendre'}`}>{hasImage(a) ? 'photo presente' : 'photo a venir'}</span>
          </li>
        ))}
      </ul>

      <p class="mt-10 max-w-prose text-noir/75">
        Pour saisir une œuvre pas à pas — avec un <strong>garde-fou avant publication</strong> —
        utilisez l’<a href="#intake" class="link-quiet font-semibold">assistant « Ajouter une œuvre »</a> ci-dessous.
      </p>
    </section>

    <!-- ASSISTANT « AJOUTER UNE ŒUVRE » (prototype, ne sauvegarde pas) -->
    <section id="intake" class="scroll-mt-28">
      <details class="cockpit-module mt-16">
      <summary class="cockpit-summary">
        <h2 class="text-h2 font-serif text-encre">Ajouter une œuvre</h2>
        <span class="cockpit-chevron" aria-hidden="true">▸</span>
      </summary>
      <div class="rule-gold mt-4" aria-hidden="true"></div>
      <p class="mt-4 max-w-prose text-noir/80">
        Trois étapes simples pour préparer une œuvre <strong>sans se tromper</strong>, puis copier un
        résumé propre à transmettre. <strong>Rien n’est sauvegardé ni publié ici</strong> : on prépare,
        un humain valide.
      </p>

      <!-- Progression en 3 étapes -->
      <div class="mt-6 frame-gallery p-5">
        <div class="flex flex-wrap items-baseline justify-between gap-3">
          <p class="text-eyebrow uppercase tracking-[0.16em] text-cendre">Progression</p>
          <p class="text-sm text-cendre"><span id="w-step">0</span> / 3 étapes préparées</p>
        </div>
        <div class="mt-3 h-2 w-full overflow-hidden rounded-full bg-brume">
          <div id="w-bar" class="h-full bg-or transition-all" style="width:0%"></div>
        </div>
        <ul class="mt-4 flex flex-wrap gap-2">
          {addArtworkSteps.map((s) => (
            <li data-stepbadge={s.n} class="rounded-full border border-cendre/30 px-3 py-1 text-xs text-cendre">Étape {s.n} · {s.label}</li>
          ))}
        </ul>
      </div>

      <form id="w-form" class="mt-6 grid max-w-3xl gap-6" onsubmit="return false">
        <!-- ÉTAPE 1 — Informations essentielles -->
        <fieldset class="frame-gallery p-5">
          <legend class="px-1 font-serif text-lg italic text-encre">{addArtworkSteps[0].n} · {addArtworkSteps[0].label}</legend>
          <p class="mt-1 text-sm text-cendre">{addArtworkSteps[0].help}</p>
          <div class="mt-4 grid gap-4 sm:grid-cols-2">
            <label class="text-sm">Titre
              <input id="w-title" type="text" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none" />
            </label>
            <label class="text-sm">Série <span class="text-cendre">(optionnel)</span>
              <input id="w-series" type="text" placeholder="Bleu Cendres" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none" />
            </label>
            <label class="text-sm">Année <span class="text-cendre">(sinon vide)</span>
              <input id="w-year" type="text" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none" />
            </label>
            <label class="text-sm">Dimensions <span class="text-cendre">(ne pas inventer)</span>
              <input id="w-dimensions" type="text" placeholder="60 × 73 cm" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none" />
            </label>
            <label class="text-sm">Technique
              <input id="w-technique" type="text" placeholder="Acrylique sur toile" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none" />
            </label>
            <label class="text-sm">Support
              <input id="w-support" type="text" placeholder="Toile recyclée" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none" />
            </label>
            <label class="text-sm sm:col-span-2">Statut
              <select id="w-status" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none">
                <option value="available">Disponible</option>
                <option value="reserved">Réservée</option>
                <option value="sold">Vendue</option>
                <option value="on-request">Sur demande</option>
              </select>
            </label>
          </div>
        </fieldset>

        <!-- ÉTAPE 2 — Images & description -->
        <fieldset class="frame-gallery p-5">
          <legend class="px-1 font-serif text-lg italic text-encre">{addArtworkSteps[1].n} · {addArtworkSteps[1].label}</legend>
          <p class="mt-1 text-sm text-cendre">{addArtworkSteps[1].help}</p>
          <div class="mt-4 grid gap-4 sm:grid-cols-2">
            <label class="text-sm">Image principale (nom de fichier)
              <input id="w-image" type="text" placeholder="/images/artworks/mon-oeuvre.webp" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none" />
            </label>
            <label class="text-sm">Images détails <span class="text-cendre">(optionnel)</span>
              <input id="w-detail" type="text" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none" />
            </label>
            <label class="text-sm sm:col-span-2">Description courte (quelques mots)
              <textarea id="w-description" rows="2" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none"></textarea>
            </label>
            <label class="text-sm sm:col-span-2">Alt text (décrire vraiment l’œuvre)
              <input id="w-alt" type="text" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none" />
            </label>
          </div>
          <div class="mt-3 space-y-2 text-sm">
            <label class="flex items-center gap-2"><input id="w-web" type="checkbox" /> Version web compressée prête (à publier)</label>
