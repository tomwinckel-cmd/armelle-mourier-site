            <p class="mt-1 text-sm text-noir/75">{s.description}</p>
            <p class="mt-2 text-xs text-cendre">{s.fields.join(' · ')}</p>
          </article>
        ))}
      </div>

      <!-- Préparer la transaction (NE SAUVEGARDE PAS) -->
      <h3 class="mt-10 text-h3 font-serif text-encre">Préparer le dossier</h3>
