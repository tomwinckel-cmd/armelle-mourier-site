---
import { theme } from '../data/theme';

interface Props {
  title?: string;
  dimensions?: string;
  /** Petite légende sobre optionnelle (ex. micro-légende du hero). */
  note?: string;
  class?: string;
}
const { title = 'Œuvre à venir', dimensions, note, class: className = '' } = Astro.props;

// Style piloté par le cockpit (src/data/theme.ts → fragment).
const { placeholderStyle, accentStroke } = theme.fragment;
const isFragment = placeholderStyle === 'fragment';

// Couches picturales : bleu profond, bleu clair, touches d'or, sur ivoire.
// L'alpha est mis à l'échelle par --fragment-strength (cockpit).
const fragmentBg = [
  'radial-gradient(58% 52% at 78% 20%, rgb(var(--c-blue-soft) / calc(0.55 * var(--fragment-strength))), transparent 70%)',
  'radial-gradient(64% 58% at 22% 82%, rgb(var(--c-encre) / calc(0.45 * var(--fragment-strength))), transparent 72%)',
  'radial-gradient(30% 26% at 60% 58%, rgb(var(--c-or) / calc(0.42 * var(--fragment-strength))), transparent 70%)',
  'linear-gradient(135deg, rgb(var(--c-brume)), rgb(var(--c-paper)) 52%, rgb(var(--c-brume)))',
].join(', ');

// Matière très subtile (striations façon toile/geste).
const matterBg =
  'repeating-linear-gradient(115deg, transparent 0 7px, rgb(var(--c-encre) / calc(0.022 * var(--fragment-strength))) 7px 8px)';
---
{isFragment ? (
  <div
    class={`relative isolate flex h-full w-full items-center justify-center overflow-hidden p-8 ${className}`}
    style={`background: ${fragmentBg};`}
  >
    {/* Matière (décoratif) */}
    <div aria-hidden="true" class="pointer-events-none absolute inset-0" style={`background: ${matterBg};`}></div>

    {/* Geste pictural — bleu clair + or (décoratif) */}
    {accentStroke && (
      <svg
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 h-full w-full"
        viewBox="0 0 100 125"
        preserveAspectRatio="xMidYMid slice"
        fill="none"
      >
        <path
          d="M4 84 C 26 68, 40 60, 60 40"
          style="stroke: rgb(var(--c-blue-soft)); stroke-opacity: calc(0.38 * var(--fragment-strength)); stroke-width: 3;"
          stroke-linecap="round"
        />
        <path
          d="M8 98 C 32 72, 40 64, 60 52 S 86 28, 96 14"
          style="stroke: rgb(var(--c-or)); stroke-opacity: calc(0.5 * var(--fragment-strength)); stroke-width: 1.6;"
          stroke-linecap="round"
        />
      </svg>
    )}

    {/* Cadre type carte de visite (décoratif) */}
    <div aria-hidden="true" class="pointer-events-none absolute inset-3 rounded-card border border-or/25"></div>

    {/* Légende lisible */}
    <div class="relative max-w-[16rem] text-center">
      <div class="mx-auto mb-4 h-px w-16 bg-or/70"></div>
      <p class="font-serif text-2xl leading-tight text-encre">{title}</p>
      {dimensions && <p class="mt-2 text-sm uppercase tracking-[0.16em] text-cendre">{dimensions}</p>}
      {note && <p class="mt-4 font-serif text-sm italic leading-snug text-encre/75">{note}</p>}
    </div>
  </div>
) : (
  <div class={`flex h-full w-full items-center justify-center bg-brume p-8 ${className}`}>
    <div class="max-w-[16rem] text-center">
      <div class="mx-auto mb-4 h-px w-16 bg-or/70"></div>
      <p class="font-serif text-2xl leading-tight text-encre">{title}</p>
      {dimensions && <p class="mt-2 text-sm uppercase tracking-[0.16em] text-cendre">{dimensions}</p>}
      {note && <p class="mt-4 text-sm italic leading-snug text-encre/75">{note}</p>}
    </div>
  </div>
)}
