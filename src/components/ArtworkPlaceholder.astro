---
interface Props {
  title?: string;
  dimensions?: string;
  class?: string;
}
const { title = 'Œuvre à venir', dimensions, class: className = '' } = Astro.props;
---
<div class={`flex h-full w-full items-center justify-center bg-[radial-gradient(circle_at_30%_20%,rgba(169,121,31,0.20),transparent_32%),linear-gradient(135deg,#E9E5DA,#F5F2EB_48%,#dfe6e4)] p-8 ${className}`}>
  <div class="max-w-[16rem] text-center">
    <div class="mx-auto mb-5 h-px w-24 bg-or/70"></div>
    <p class="font-serif text-2xl leading-tight text-encre">{title}</p>
    {dimensions && <p class="mt-3 text-sm uppercase tracking-[0.18em] text-cendre">{dimensions}</p>}
    <p class="mt-5 text-xs uppercase tracking-[0.22em] text-cendre">Image à ajouter</p>
  </div>
</div>
