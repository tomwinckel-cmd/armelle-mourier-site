---
import { theme } from '../data/theme';

interface Props {
  title?: string;
  dimensions?: string;
  /** Petite légende sobre optionnelle. */
  note?: string;
  class?: string;
}
const { title, dimensions, note, class: className = '' } = Astro.props;

const plain = theme.fragment.placeholderStyle === 'plain';
const rectangles = !plain && theme.identity.fragmentStyle === 'blue-gold-rectangles';
const accentStroke = theme.fragment.accentStroke;
const hasLabel = Boolean(title || note);
---
{rectangles ? (
  <div class={`relative isolate h-full w-full overflow-hidden ${className}`} style="background: linear-gradient(160deg, rgb(var(--c-paper)), rgb(var(--c-brume)) 60%, rgb(var(--c-paper)));">
    {/* Composition picturale — blocs verticaux bleu profond / noir / bleu clair,
        bords coupés (overflow) pour des limites imparfaites. Décoratif. */}
    <div aria-hidden="true" class="pointer-events-none absolute inset-0">
      {/* masse bleu profond */}
      <span class="absolute" style="left:12%; top:-4%; width:27%; height:92%; transform: rotate(-1.6deg); background: rgb(var(--c-encre) / calc(0.78 + 0.2 * var(--blue-depth)));"></span>
      {/* colonne noire (signature/masse sombre) */}
      <span class="absolute" style="left:39%; top:10%; width:9%; height:82%; transform: rotate(1deg); background: rgb(var(--c-noir) / 0.9);"></span>
      {/* bloc bleu clair (matière, lumière) */}
      <span class="absolute" style="left:58%; top:20%; width:24%; height:66%; transform: rotate(-1deg); background: rgb(var(--c-blue-soft) / calc(0.5 + 0.4 * var(--blue-depth)));"></span>
      {/* petit aplat bleu clair secondaire */}
      <span class="absolute" style="left:80%; top:6%; width:11%; height:34%; transform: rotate(2deg); background: rgb(var(--c-blue-soft) / 0.45);"></span>
      {/* traces / filets d'or (pigment) */}
      <span class="absolute" style="left:35%; top:4%; width:2px; height:90%; transform: rotate(0.6deg); background: rgb(var(--c-or) / var(--gold-trace));"></span>
      <span class="absolute" style="left:69%; top:14%; width:2px; height:74%; background: rgb(var(--c-or) / calc(0.8 * var(--gold-trace)));"></span>
      <span class="absolute" style="left:10%; top:72%; width:60%; height:2px; transform: rotate(-1.2deg); background: rgb(var(--c-or) / calc(0.9 * var(--gold-trace)));"></span>
    </div>

    {/* Geste / grattage doré (SVG léger, décoratif) */}
    {accentStroke && (
      <svg aria-hidden="true" class="pointer-events-none absolute inset-0 h-full w-full" viewBox="0 0 100 125" preserveAspectRatio="xMidYMid slice" fill="none">
        <path d="M18 116 C 30 70, 28 52, 44 8" style="stroke: rgb(var(--c-or)); stroke-opacity: calc(0.55 * var(--gold-trace) * 1.4); stroke-width: 1.4;" stroke-linecap="round" />
      </svg>
    )}

    {/* Matière (striations très subtiles) */}
    <div aria-hidden="true" class="pointer-events-none absolute inset-0" style="background: repeating-linear-gradient(102deg, transparent 0 6px, rgb(var(--c-noir) / 0.03) 6px 7px);"></div>

    {/* Cartel discret (uniquement hors carte d'œuvre, ex. portrait) */}
    {hasLabel && (
      <div class="absolute bottom-0 left-0 right-0 bg-paper/85 px-4 py-3 backdrop-blur-[1px]">
        {title && <p class="font-serif italic leading-tight text-encre">{title}</p>}
        {dimensions && <p class="mt-0.5 text-xs uppercase tracking-[0.16em] text-cendre">{dimensions}</p>}
        {note && <p class="mt-1 text-sm italic text-encre/75">{note}</p>}
      </div>
    )}
  </div>
) : (
  <div class={`flex h-full w-full items-center justify-center bg-brume p-8 ${className}`}>
    <div class="max-w-[16rem] text-center">
      <div class="mx-auto mb-4 h-px w-16 bg-or/70"></div>
      {title && <p class="font-serif text-2xl leading-tight text-encre">{title}</p>}
      {dimensions && <p class="mt-2 text-sm uppercase tracking-[0.16em] text-cendre">{dimensions}</p>}
      {note && <p class="mt-4 text-sm italic leading-snug text-encre/75">{note}</p>}
    </div>
  </div>
)}
