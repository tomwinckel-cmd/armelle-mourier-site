  width={width}
  height="14"
  viewBox="0 0 120 14"
  fill="none"
  aria-hidden="true"
  focusable="false"
>
  <path
    d="M2 8.4C18.2 2.8 34.7 3.1 50.9 6.7C66.8 10.2 83.6 13.3 118 4.2"
    stroke="currentColor"
    stroke-width="3"
    stroke-linecap="round"
  />
</svg>
