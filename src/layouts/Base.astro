---
import '../styles/global.css';
import { site, defaultKeywords } from '../data/site';
import { theme, themeCssVars } from '../data/theme';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  keywords?: string[];
  image?: string;
  /** Texte alternatif de l'image OG/Twitter. */
  imageAlt?: string;
  /** Type Open Graph (ex. 'website', 'article', 'profile'). */
  ogType?: string;
  jsonld?: Record<string, unknown> | Record<string, unknown>[];
  /** Empêche l'indexation (pages internes : ex. /cockpit-roadmap). */
  noindex?: boolean;
}
const {
  title = `${site.artistName} — ${site.role}`,
  description = site.baseline,
  keywords = [],
  // Image de partage par défaut. ⚠️ Remplacer par un vrai 1200×630 (voir docs/seo-checklist.md).
  image = '/images/og/og-default.svg',
  imageAlt,
  ogType = 'website',
  jsonld,
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, site.url).href;
const mergedKeywords = Array.from(new Set([...defaultKeywords, ...keywords])).join(', ');
const jsonLdArray = Array.isArray(jsonld) ? jsonld : jsonld ? [jsonld] : [];

// Image de partage : URL absolue + type MIME déduit de l'extension.
const imageUrl = new URL(image, site.url).href;
const imageType = image.endsWith('.svg')
  ? 'image/svg+xml'
  : image.endsWith('.png')
    ? 'image/png'
    : 'image/jpeg';
const imageAltText = imageAlt ?? `${site.artistName} — ${site.role}`;

// Thème pilotable (cockpit) : on traduit src/data/theme.ts en variables CSS.
// Modifier couleurs / typo / arrondis / texture se fait dans theme.ts, pas ici.
const cssVars = themeCssVars(theme);
const themeStyle = Object.entries(cssVars).map(([k, v]) => `${k}: ${v};`).join(' ');
const themeColor = `rgb(${cssVars['--c-encre'].split(' ').join(', ')})`;
---
<!doctype html>
<html lang={site.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={mergedKeywords} />
    <meta name="author" content={site.artistName} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />

    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content={site.locale} />
    <meta property="og:site_name" content={site.artistName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:type" content={imageType} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={imageAltText} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={imageAltText} />
    <meta name="theme-color" content={themeColor} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&family=Mulish:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    {jsonLdArray.map((item) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}

    <!-- Thème injecté depuis src/data/theme.ts (surcharge les défauts de global.css). -->
    <style is:inline set:html={`:root { ${themeStyle} }`}></style>
  </head>
  <body
    class="min-h-screen bg-paper font-sans text-noir antialiased"
    data-texture={theme.texture.enabled && theme.texture.intensity !== 'none' ? 'on' : 'off'}
    data-btn-style={theme.buttons.style}
    data-signature={theme.typography.signature}
    data-identity={theme.identity.visualIdentity}
    data-buttons={theme.identity.buttonMode}
    data-cards={theme.identity.cardMode}
    data-accent={theme.identity.accentMode}
    data-menu={theme.identity.menuMode}
    data-fragment={theme.identity.fragmentStyle}
    data-paper={theme.identity.paperMood}
  >
    <a href="#contenu" class="skip-link">Aller au contenu</a>

    <Header />

    <main id="contenu">
      <slot />
    </main>

    <Footer />

    <!-- Navigation : chaque page s'ouvre EN HAUT (pas de scroll restauré).
         Ne bloque jamais la navigation des liens (<a href> standards). -->
    <script is:inline>
      if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
      // pageshow couvre le chargement normal ET le retour via bfcache.
      window.addEventListener('pageshow', function () {
        if (!location.hash) window.scrollTo({ top: 0, left: 0, behavior: 'instant' });
      });
    </script>

    <script>
      const revealEls = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window) {
        const obs = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              obs.unobserve(entry.target);
            }
          });
        }, { threshold: 0.08 });
        revealEls.forEach((el) => obs.observe(el));
      } else {
        revealEls.forEach((el) => el.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
