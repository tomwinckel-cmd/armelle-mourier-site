---
import Base from '../layouts/Base.astro';
import SectionTitle from '../components/SectionTitle.astro';
import ArtworkGrid from '../components/ArtworkGrid.astro';
import ArtworkPlaceholder from '../components/ArtworkPlaceholder.astro';
import Trait from '../components/Trait.astro';
import { site } from '../data/site';
import { theme } from '../data/theme';
import { featuredArtworks, availableArtworks } from '../data/artworks';
import { splitExhibitions } from '../data/exhibitions';

const { upcoming, past } = splitExhibitions();
const featured = featuredArtworks.length ? featuredArtworks.slice(0, 3) : availableArtworks.slice(0, 3);
const recent = [...upcoming, ...past].slice(0, 3);

const visualArtistLd = {
  '@context': 'https://schema.org',
  '@type': 'VisualArtist',
  name: site.artistName,
  jobTitle: site.role,
  url: site.url,
  address: {
    '@type': 'PostalAddress',
    addressLocality: site.city,
    addressRegion: site.region,
    addressCountry: site.country,
  },
  knowsAbout: ['peinture abstraite', 'peinture acrylique', 'art contemporain', 'Bleu Cendres'],
};
---
<Base
  title={`${site.artistName} — ${site.role}`}
  description={`${site.manifesto} ${site.baseline}`}
  keywords={['Armelle Mourier', 'artiste peintre Dijon', 'tableaux disponibles', 'peinture contemporaine']}
  jsonld={visualArtistLd}
>
  <section class="shell grid items-center gap-10 pb-section pt-10 sm:pt-14 lg:min-h-[78vh] lg:grid-cols-[1.05fr_0.95fr] lg:gap-14">
    <div class="reveal is-visible">
      <p class="eyebrow mb-4">{theme.hero.eyebrow}</p>
      <h1 class="signature text-display text-encre">{site.artistName}</h1>
      {theme.hero.showSignatureLine && <Trait class="mt-5 text-or" width="9rem" />}
      <p class="mt-7 max-w-prose text-lg leading-relaxed text-noir/80 sm:text-xl">{theme.hero.lead}</p>
      <p class="mt-4 max-w-prose font-serif text-xl italic leading-snug text-encre sm:text-2xl">{site.manifesto}</p>
      <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
        <a href="/oeuvres" class="btn btn-primary">Découvrir les œuvres</a>
        <a href="/disponibles" class="btn btn-ghost">Tableaux disponibles</a>
        <a href="/contact" class="btn btn-gold">Contacter l’artiste</a>
      </div>
    </div>

    <div class="reveal is-visible">
      <!-- Fragment d'œuvre encadré — clin d'œil à la carte de visite :
           filet or discret, lueur bleu clair, signature en surimpression. -->
      <figure class="relative mx-auto max-w-md lg:max-w-none">
        {theme.hero.showArtworkFragment && (
          <div
            class="absolute -inset-5 -z-10 rounded-[1.5rem]"
            aria-hidden="true"
            style="background: radial-gradient(70% 70% at 70% 20%, rgb(var(--c-blue-soft) / calc(0.3 * var(--fragment-strength))), transparent 70%);"
          ></div>
        )}
        <div class={`overflow-hidden rounded-card bg-brume shadow-soft ${theme.hero.showArtworkFragment ? 'ring-1 ring-or/30 ring-offset-4 ring-offset-paper' : ''}`}>
          <div class="aspect-[4/5]">
            {featured[0]?.image ? (
              <img src={featured[0].image} alt={featured[0].alt} class="h-full w-full object-cover" loading="eager" decoding="async" />
            ) : (
              <ArtworkPlaceholder title={featured[0]?.title ?? site.artistName} dimensions={featured[0]?.dimensions} />
            )}
          </div>
        </div>
        {theme.hero.showArtworkFragment && featured[0]?.title && (
          <figcaption class="mt-3 flex items-center justify-between gap-3 text-sm text-cendre">
            <span class="font-serif italic text-encre">{featured[0].title}</span>
            {featured[0].series && <span class="text-eyebrow uppercase tracking-[0.16em]">{featured[0].series}</span>}
          </figcaption>
        )}
        {theme.hero.showArtworkFragment && !featured[0]?.image && (
          <p class="mt-1 text-sm italic text-cendre">Fragment d’univers — bleu, matière et lumière.</p>
        )}
      </figure>
    </div>
  </section>

  <section class="bg-brume py-section">
    <div class="shell">
      <SectionTitle
        eyebrow="Galerie"
        title="Œuvres mises en lumière"
        lead="Une première traversée de l’univers pictural : couleur, matière, mémoire des lieux et souffle intérieur."
      />
      <div class="mt-12">
        <ArtworkGrid artworks={featured} />
      </div>
      <div class="mt-10">
        <a href="/oeuvres" class="link-quiet font-semibold">Voir toute la galerie →</a>
      </div>
    </div>
  </section>

  <section class="shell grid gap-6 py-section lg:grid-cols-2 lg:gap-10">
    <div class={`reveal rounded-card p-7 sm:p-9 ${theme.saleMode.highlightOnHome ? 'bg-brume ring-1 ring-or/25' : ''}`}>
      <p class="eyebrow mb-3">Acquisition</p>
      <h2 class="text-h1 font-serif text-encre">Tableaux disponibles</h2>
      <p class="mt-6 leading-relaxed text-noir/80">
        Certaines œuvres originales peuvent être acquises ou réservées en lien direct avec l’artiste.
        La vente reste volontairement sobre : une conversation, une demande de catalogue, le temps de choisir.
      </p>
      <a href="/disponibles" class="btn btn-primary mt-7">Découvrir les œuvres disponibles</a>
    </div>
    <div class="reveal rounded-card p-7 sm:p-9">
      <p class="eyebrow mb-3">Livre & poésie</p>
      <h2 class="text-h1 font-serif text-encre">Bleu Cendres</h2>
      <p class="mt-6 leading-relaxed text-noir/80">
        Un recueil de poésie illustré où les toiles dorées et bleues d’Armelle Mourier dialoguent
        avec les mots de Louise Dupré.
      </p>
      <a href="/bleu-cendres" class="btn btn-ghost mt-7">Entrer dans Bleu Cendres</a>
    </div>
  </section>

  <section class="bg-encre py-section text-paper">
    <div class="shell">
      <SectionTitle
        eyebrow="Présence"
        title="Expositions récentes & à venir"
        lead="Une chronologie vivante entre expositions, performances, résidences et rencontres."
      />
      <div class="mt-12 grid gap-5 md:grid-cols-3">
        {recent.map((e) => (
          <article class="reveal rounded-card border border-paper/15 bg-paper/5 p-6 transition-colors hover:border-or/40">
            <p class="text-sm uppercase tracking-[0.18em] text-paper/50">{e.dateLabel}</p>
            <h3 class="mt-3 font-serif text-2xl text-paper">{e.title}</h3>
            <p class="mt-2 text-paper/70">{[e.location, e.city].filter(Boolean).join(' — ')}</p>
          </article>
        ))}
      </div>
      <a href="/expositions" class="mt-10 inline-flex text-paper underline decoration-or underline-offset-4">Voir la chronologie →</a>
    </div>
  </section>
</Base>
