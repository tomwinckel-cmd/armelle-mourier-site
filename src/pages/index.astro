---
import Base from '../layouts/Base.astro';
import SectionTitle from '../components/SectionTitle.astro';
import ArtworkGrid from '../components/ArtworkGrid.astro';
import ArtworkPlaceholder from '../components/ArtworkPlaceholder.astro';
import Trait from '../components/Trait.astro';
import { site } from '../data/site';
import { theme } from '../data/theme';
import { featuredArtworks, availableArtworks } from '../data/artworks';
import { splitExhibitions } from '../data/exhibitions';

const { upcoming, past } = splitExhibitions();
const featured = featuredArtworks.length ? featuredArtworks.slice(0, 3) : availableArtworks.slice(0, 3);
const recent = [...upcoming, ...past].slice(0, 3);

const visualArtistLd = {
  '@context': 'https://schema.org',
  '@type': 'VisualArtist',
  name: site.artistName,
  jobTitle: site.role,
  url: site.url,
  address: {
    '@type': 'PostalAddress',
    addressLocality: site.city,
    addressRegion: site.region,
    addressCountry: site.country,
  },
  knowsAbout: ['peinture abstraite', 'peinture acrylique', 'art contemporain', 'Bleu Cendres'],
};
---
<Base
  title={`${site.artistName} — ${site.role}`}
  description={`${site.manifesto} ${site.baseline}`}
  keywords={['Armelle Mourier', 'artiste peintre Dijon', 'tableaux disponibles', 'peinture contemporaine']}
  jsonld={visualArtistLd}
>
  <section class="shell grid items-center gap-12 pb-section pt-10 sm:pt-16 lg:min-h-[84vh] lg:grid-cols-[0.92fr_1.08fr] lg:gap-16">
    <div class="reveal is-visible">
      <p class="eyebrow mb-5">{theme.hero.eyebrow}</p>
      <h1 class="signature text-display text-encre">{site.artistName}</h1>
      {theme.hero.showSignatureLine && <Trait class="mt-4 text-or" width="12rem" />}
      <p class="mt-3 text-sm uppercase tracking-[0.18em] text-cendre">Atelier · {site.city}, {site.region}</p>
      <p class="mt-8 max-w-prose font-serif text-2xl italic leading-snug text-encre sm:text-3xl">{site.manifesto}</p>
      <p class="mt-5 max-w-prose leading-relaxed text-noir/75">{theme.hero.lead}</p>
      {/* Entrées comme un index de carnet, pas une rangée de boutons marketing. */}
      <ul class="mt-10 flex flex-col items-start gap-4">
        <li><a href="/oeuvres" class="btn btn-primary">Découvrir les œuvres</a></li>
        <li><a href="/disponibles" class="btn btn-ghost">Voir les tableaux disponibles</a></li>
        <li><a href="/contact" class="btn btn-gold">Écrire à l’artiste</a></li>
      </ul>
    </div>

    <div class="reveal is-visible">
      {/* Carte de visite agrandie : fragment pictural monté sur papier,
          légèrement incliné, posé en asymétrie. */}
      <figure class="relative mx-auto max-w-xs sm:max-w-sm lg:ml-auto lg:mr-0 lg:max-w-none lg:translate-y-4">
        {theme.hero.showArtworkFragment && (
          <div
            class="absolute -inset-6 -z-10"
            aria-hidden="true"
            style="background: radial-gradient(60% 60% at 72% 18%, rgb(var(--c-blue-soft) / calc(0.22 * var(--fragment-strength))), transparent 72%);"
          ></div>
        )}
        <div class="frame-gallery overflow-hidden p-[7px] lg:rotate-[1.6deg]">
          <div class="aspect-[4/5] overflow-hidden">
            {featured[0]?.image ? (
              <img src={featured[0].image} alt={featured[0].alt} class="h-full w-full object-cover" loading="eager" decoding="async" />
            ) : (
              <ArtworkPlaceholder />
            )}
          </div>
        </div>
        <figcaption class="mt-4 flex items-baseline justify-between gap-3 lg:rotate-[1.6deg]">
          <span class="font-serif italic text-encre">{featured[0]?.title ?? 'Fragment d’atelier'}</span>
          <span class="text-eyebrow uppercase tracking-[0.18em] text-cendre">{featured[0]?.series ?? 'Bleu · matière'}</span>
        </figcaption>
      </figure>
    </div>
  </section>

  <section class="bg-brume py-section">
    <div class="shell">
      <SectionTitle
        eyebrow="Galerie"
        title="Œuvres mises en lumière"
        lead="Une première traversée de l’univers pictural : couleur, matière, mémoire des lieux et souffle intérieur."
      />
      <div class="mt-12">
        <ArtworkGrid artworks={featured} />
      </div>
      <div class="mt-10">
        <a href="/oeuvres" class="link-quiet font-semibold">Voir toute la galerie →</a>
      </div>
    </div>
  </section>

  <section class="shell grid gap-10 py-section lg:grid-cols-2 lg:gap-14">
    <div class={`reveal border-l-2 pl-6 sm:pl-8 ${theme.saleMode.highlightOnHome ? 'border-or/60' : 'border-cendre/30'}`}>
      <p class="eyebrow mb-3">Acquisition</p>
      <h2 class="text-h1 font-serif text-encre">Tableaux disponibles</h2>
      <p class="mt-6 leading-relaxed text-noir/80">
        Certaines œuvres originales peuvent être acquises ou réservées, en lien direct avec l’artiste.
        L’acquisition reste une conversation : une demande, le temps de choisir, jamais un panier.
      </p>
      <a href="/disponibles" class="btn btn-primary mt-7">Voir les tableaux disponibles</a>
    </div>
    <div class="reveal border-l-2 border-cendre/30 pl-6 sm:pl-8">
      <p class="eyebrow mb-3">Livre & poésie</p>
      <h2 class="text-h1 font-serif text-encre">Bleu Cendres</h2>
      <p class="mt-6 leading-relaxed text-noir/80">
        Un recueil de poésie illustré où les toiles dorées et bleues d’Armelle Mourier dialoguent
        avec les mots de Louise Dupré.
      </p>
      <a href="/bleu-cendres" class="btn btn-ghost mt-7">Entrer dans Bleu Cendres</a>
    </div>
  </section>

  <section class="bg-encre py-section text-paper">
    <div class="shell">
      <SectionTitle
        eyebrow="Présence"
        title="Expositions récentes & à venir"
        lead="Une chronologie vivante entre expositions, performances, résidences et rencontres."
      />
      <div class="mt-12 grid gap-5 md:grid-cols-3">
        {recent.map((e) => (
          <article class="reveal border-t border-paper/25 pt-5 transition-colors hover:border-or/60">
            <p class="text-sm uppercase tracking-[0.18em] text-paper/50">{e.dateLabel}</p>
            <h3 class="mt-3 font-serif text-2xl text-paper">{e.title}</h3>
            <p class="mt-2 text-paper/70">{[e.location, e.city].filter(Boolean).join(' — ')}</p>
          </article>
        ))}
      </div>
      <a href="/expositions" class="mt-10 inline-flex text-paper underline decoration-or underline-offset-4">Voir la chronologie →</a>
    </div>
  </section>
</Base>
