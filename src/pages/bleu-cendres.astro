---
import Base from '../layouts/Base.astro';
import SectionTitle from '../components/SectionTitle.astro';
import ArtworkPlaceholder from '../components/ArtworkPlaceholder.astro';
import Trait from '../components/Trait.astro';
import { bleuCendres } from '../content/bio';
import { artworks } from '../data/artworks';
import { site } from '../data/site';

// Œuvres rattachées à la série Bleu Cendres
const related = artworks.filter((a) => a.series === 'Bleu Cendres');

const bookLd = {
  '@context': 'https://schema.org',
  '@type': 'Book',
  name: 'Bleu Cendres',
  bookFormat: 'https://schema.org/Hardcover',
  inLanguage: 'fr',
  datePublished: '2024-03',
  publisher: { '@type': 'Organization', name: 'L’Atelier des Noyers' },
  illustrator: { '@type': 'Person', name: site.artistName },
  author: { '@type': 'Person', name: 'Louise Dupré' },
  about: 'Recueil de poésie illustré',
};
---
<Base
  title="Bleu Cendres — recueil de poésie illustré | Armelle Mourier"
  description="Bleu Cendres : recueil de poésie illustré (mars 2024, L’Atelier des Noyers). Les toiles dorées et bleues d’Armelle Mourier rencontrent les poèmes de Louise Dupré."
  keywords={['Bleu Cendres', 'recueil de poésie illustré', 'Louise Dupré', 'Armelle Mourier', 'L’Atelier des Noyers', 'peinture et poésie']}
  jsonld={bookLd}
>
  <!-- INTRO + COUVERTURE -->
  <section class="shell pb-section pt-12 sm:pt-16">
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <div class="reveal is-visible">
        <p class="eyebrow mb-3">Le projet</p>
        <h1 class="text-h1 font-serif text-encre">Bleu Cendres</h1>
        <Trait class="mt-5 text-or" width="7rem" />
        <p class="mt-7 max-w-prose font-serif text-h3 italic leading-snug text-encre/90">
          {bleuCendres.lead}
        </p>
      </div>

      <figure class="reveal is-visible">
        <div class="aspect-[5/4] w-full overflow-hidden rounded-card shadow-soft">
          {bleuCendres.cover ? (
            <img src={bleuCendres.cover} alt={bleuCendres.coverAlt} class="h-full w-full object-cover" loading="eager" />
          ) : (
            <ArtworkPlaceholder title="Bleu Cendres" dimensions="Recueil illustré, 2024" />
          )}
        </div>
      </figure>
    </div>
  </section>

  <!-- BLEU, CENDRE, OR (évocation de la gamme) -->
  <section class="shell pb-section">
    <p class="eyebrow reveal mb-3">La gamme</p>
    <h2 class="reveal text-h2 font-serif text-encre">{bleuCendres.palette.title}</h2>
    <Trait class="reveal mt-5 text-or" width="7rem" />
    <p class="reveal mt-6 max-w-prose text-noir/75">{bleuCendres.palette.note}</p>
    <div class="mt-10 grid gap-6 sm:grid-cols-3">
      {bleuCendres.palette.items.map((p) => (
        <div class="reveal frame-gallery p-6">
          <h3 class="font-serif text-2xl italic text-encre">{p.word}</h3>
          <hr class="cartel-rule mt-3" />
          <p class="mt-4 leading-relaxed text-noir/80">{p.text}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- RÉCIT + FICHE -->
  <section class="bg-brume py-section">
    <div class="shell grid gap-12 lg:grid-cols-[1.4fr_0.6fr]">
      <div class="reveal max-w-prose">
        {bleuCendres.paragraphs.map((p) => (
          <p class="mb-5 leading-relaxed text-noir/85 last:mb-0">{p}</p>
        ))}
      </div>

      <aside class="reveal">
        <h2 class="text-eyebrow uppercase tracking-[0.18em] text-cendre">Le recueil en bref</h2>
        <Trait class="mt-3 text-or" width="3rem" />
        <dl class="mt-5 divide-y divide-cendre/20">
          {bleuCendres.facts.map((f) => (
            <div class="flex flex-col gap-0.5 py-3">
              <dt class="text-eyebrow uppercase tracking-[0.14em] text-cendre">{f.label}</dt>
              <dd class="font-serif text-lg text-encre">{f.value}</dd>
            </div>
          ))}
        </dl>
      </aside>
    </div>
  </section>

  <!-- ŒUVRES ASSOCIÉES -->
  {related.length > 0 && (
    <section class="shell py-section">
      <SectionTitle eyebrow="La série" title="Tableaux dorés et bleus" />
      <p class="reveal mt-6 max-w-prose text-noir/75">
        Quelques toiles de la série qui a nourri le recueil, la résidence «&nbsp;Trait Bleu&nbsp;»
        et l’installation «&nbsp;Balade en Bleu&nbsp;».
      </p>
      <div class="mt-10 grid grid-cols-1 gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
        {related.map((a) => (
          <figure class="reveal">
            <div class="aspect-[4/5] overflow-hidden rounded-card shadow-soft">
              {a.image ? (
                <img src={a.image} alt={a.alt} class="h-full w-full object-cover" loading="lazy" />
              ) : (
                <ArtworkPlaceholder title={a.title} dimensions={a.dimensions} />
              )}
            </div>
            <figcaption class="mt-3 text-sm text-cendre">
              <span class="font-serif text-encre">{a.title}</span>
              {a.dimensions && <span> · {a.dimensions}</span>}
            </figcaption>
          </figure>
        ))}
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="shell pb-section">
    <div class="rounded-card bg-encre px-6 py-12 text-center text-paper sm:px-12">
      <Trait class="mx-auto text-or" width="6rem" />
      <h2 class="mt-5 text-h2 font-serif text-paper">Le recueil ou une toile vous intéresse&nbsp;?</h2>
      <p class="mx-auto mt-4 max-w-xl text-paper/75">
        Pour vous procurer Bleu Cendres, acquérir une œuvre de la série ou en savoir plus,
        écrivez à l’artiste. Le recueil est également disponible auprès de l’éditeur.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href="/contact?objet=bleu-cendres" class="btn border border-or/50 text-or hover:bg-or hover:text-encre">
          Contacter l’artiste
        </a>
        <a href={bleuCendres.publisherUrl} target="_blank" rel="noopener" class="btn border border-paper/30 text-paper/90 hover:border-paper hover:bg-paper hover:text-encre">
          Le recueil chez L’Atelier des Noyers ↗
        </a>
      </div>
      <p class="mt-7 flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm">
        <a href="/oeuvres" class="text-paper/85 underline decoration-or underline-offset-4 hover:text-paper">Voir les œuvres →</a>
        <a href="/demarche" class="text-paper/85 underline decoration-or underline-offset-4 hover:text-paper">Lire la démarche →</a>
      </p>
    </div>
  </section>
</Base>
