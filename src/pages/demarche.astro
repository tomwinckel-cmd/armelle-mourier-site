---
import Base from '../layouts/Base.astro';
import Trait from '../components/Trait.astro';
import { demarche } from '../content/bio';
import { site } from '../data/site';
---
<Base
  title={`Démarche artistique — ${site.artistName}`}
  description="La démarche d’Armelle Mourier : la couleur d’abord, la peinture comme catharsis et joie de vivre, la matière et le geste, le dialogue entre peinture, écriture et danse."
  keywords={['démarche artistique', 'peinture abstraite', 'peinture acrylique', 'Armelle Mourier', 'art contemporain']}
>
  <!-- INTRO -->
  <section class="shell pb-section pt-12 sm:pt-16">
    <p class="eyebrow reveal is-visible mb-3">L’atelier intérieur</p>
    <h1 class="reveal is-visible text-h1 font-serif text-encre">Démarche artistique</h1>
    <Trait class="reveal is-visible mt-5 text-or" width="7rem" />
    <p class="reveal mt-7 max-w-prose font-serif text-xl italic leading-snug text-encre sm:text-2xl">
      {demarche.lead}
    </p>
  </section>

  <!-- MATIÈRES & GESTES (repère concret) -->
  <section class="shell pb-section">
    <div class="reveal frame-gallery p-6 sm:p-8">
      <p class="text-eyebrow uppercase tracking-[0.16em] text-cendre">{demarche.materials.title}</p>
      <p class="mt-3 max-w-prose font-serif text-lg italic text-encre">{demarche.materials.note}</p>
      <ul class="mt-5 flex flex-wrap gap-2.5">
        {demarche.materials.tools.map((t) => (
          <li class="rounded-full border border-cendre/35 bg-paper/60 px-4 py-1.5 text-sm text-encre">{t}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- AXES -->
  <section class="bg-brume py-section">
    <div class="shell">
      <p class="eyebrow reveal mb-3">Les fils</p>
      <h2 class="reveal text-h2 font-serif text-encre">Ce qui traverse le travail</h2>
      <Trait class="reveal mt-5 text-or" width="7rem" />
      <div class="mt-12 grid gap-x-10 gap-y-12 sm:grid-cols-2">
        {demarche.axes.map((axe, i) => (
          <div class="reveal flex gap-5">
            <span class="shrink-0 font-serif text-2xl leading-none text-or">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div>
              <h3 class="text-h3 font-serif text-encre">{axe.title}</h3>
              <p class="mt-2 text-lg leading-relaxed text-noir/80">{axe.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CLÔTURE + CTA DOUX -->
  <section class="shell py-section">
    <div class="reveal rounded-card border border-cendre/25 px-6 py-12 sm:px-12">
      <p class="eyebrow mb-3">Voir la démarche à l’œuvre</p>
      <h2 class="text-h2 font-serif text-encre">Des fils qui se rejoignent</h2>
      <Trait class="mt-5 text-or" width="7rem" />
      <p class="mt-6 max-w-prose text-lg leading-relaxed text-noir/80">{demarche.closing}</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/oeuvres" class="btn-primary">Voir les œuvres</a>
        <a href="/disponibles" class="btn-ghost">Œuvres disponibles</a>
        <a href="/bleu-cendres" class="btn-gold">Découvrir Bleu Cendres</a>
      </div>
    </div>
  </section>
</Base>
