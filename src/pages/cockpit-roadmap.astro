  <script is:inline>
    // Copier dans le presse-papier (sans API externe). Préparation seulement.
    function flash(btn, msg) {
      const old = btn.textContent;
      btn.textContent = msg;
      setTimeout(function () { btn.textContent = old; }, 1600);
    }
    function copyText(text, btn) {
      if (navigator.clipboard) { navigator.clipboard.writeText(text).then(function () { flash(btn, 'Copie OK'); }); }
      else { flash(btn, 'Selectionnez et copiez'); }
    }
    document.querySelectorAll('[data-copy]').forEach(function (btn) {
      btn.addEventListener('click', function () { copyText(btn.getAttribute('data-copy') || '', btn); });
    });

    // --- Assistant « Ajouter une œuvre » (guide + vérifie, NE SAUVEGARDE PAS) ---
    (function () {
      var form = document.getElementById('w-form');
      if (!form) return;
      var q = String.fromCharCode(0x2019);
      function v(id) { var el = document.getElementById(id); return el ? el.value.trim() : ''; }
      function c(id) { var el = document.getElementById(id); return !!(el && el.checked); }
      function slugify(s) { return s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, ''); }
      var statusFr = { available: 'Disponible', reserved: 'Réservée', sold: 'Vendue', 'on-request': 'Sur demande' };

      function protectionNote() {
        var p = [];
        if (v('w-date')) p.push('date ' + v('w-date'));
        if (c('w-hd')) p.push('HD privée conservée hors site');
        if (c('w-proof')) p.push('preuve de création prévue (e-Soleau)');
        return p.join(' ; ') || 'à compléter';
      }
      function buildRecap() {
        return [
          'Fiche œuvre prête à transmettre',
          'Titre : ' + v('w-title'),
          'Série : ' + v('w-series'),
          'Année : ' + v('w-year'),
          'Dimensions : ' + v('w-dimensions'),
          'Technique : ' + v('w-technique'),
          'Support : ' + v('w-support'),
          'Description : ' + v('w-description'),
          'Statut : ' + (statusFr[v('w-status')] || v('w-status')),
          'Image principale : ' + v('w-image'),
          'Alt text : ' + v('w-alt'),
          'Notes protection : ' + protectionNote(),
          'Caption Instagram : ' + v('w-caption'),
          'Hashtags : ' + v('w-hashtags'),
        ].join('\n');
      }
      function buildBlock() {
        var title = v('w-title') || 'Sans titre';
        var slug = slugify(title) || 'oeuvre';
        var lines = ['{', "  id: '" + slug + "',", "  title: '" + title.split("'").join(q) + "',", "  slug: '" + slug + "',"];
        if (v('w-dimensions')) { lines.push("  dimensions: '" + v('w-dimensions') + "',"); }
        if (v('w-technique')) { lines.push("  technique: '" + v('w-technique') + "',"); }
        if (v('w-series')) { lines.push("  series: '" + v('w-series') + "',"); }
        if (v('w-year')) { lines.push("  year: '" + v('w-year') + "',"); }
        if (v('w-description')) { lines.push("  description: '" + v('w-description').split("'").join(q) + "',"); }
        lines.push("  image: '" + v('w-image') + "',");
        lines.push("  alt: '" + (v('w-alt') || title).split("'").join(q) + "',");
        lines.push("  status: '" + v('w-status') + "',");
        lines.push('},');
        return lines.join('\n');
      }
      var keys = ['w-title', 'w-series', 'w-year', 'w-dimensions', 'w-technique', 'w-support', 'w-description', 'w-keywords', 'w-image', 'w-alt', 'w-caption', 'w-hashtags', 'w-date'];
      var checks = ['w-web', 'w-hd', 'w-proof', 'w-saleok'];
      function update() {
        var filled = 1, total = keys.length + checks.length + 1; // statut toujours renseigné
        keys.forEach(function (k) { if (v(k)) filled++; });
        checks.forEach(function (k) { if (c(k)) filled++; });
        var score = Math.round((filled / total) * 100);
        var bar = document.getElementById('w-bar'); if (bar) bar.style.width = score + '%';
        var sc = document.getElementById('w-score'); if (sc) sc.textContent = String(score);
        var lvl = document.getElementById('w-level');
        if (lvl) lvl.textContent = score >= 80 ? 'Prêt à valider' : (score >= 40 ? 'Presque prêt' : 'Brouillon');
        var got = {
          fiche: !!(v('w-title') && v('w-dimensions') && v('w-technique') && v('w-description')),
          image: !!(v('w-image') && v('w-alt') && c('w-web') && c('w-hd')),
          protection: !!(v('w-date') && c('w-proof')),
          social: !!(v('w-caption') && v('w-hashtags')),
          sale: c('w-saleok'),
        };
        document.querySelectorAll('[data-badge]').forEach(function (el) {
          var on = got[el.getAttribute('data-badge')];
          el.className = 'rounded-full px-3 py-1 text-xs ' + (on ? 'border border-or/60 bg-or/10 text-encre' : 'border border-cendre/30 text-cendre');
        });
        var labels = { 'w-title': 'titre', 'w-dimensions': 'dimensions', 'w-technique': 'technique', 'w-image': 'image', 'w-alt': 'alt text' };
        var miss = [];
        Object.keys(labels).forEach(function (k) { if (!v(k)) miss.push(labels[k]); });
        var mEl = document.getElementById('w-missing');
        if (mEl) mEl.textContent = 'Champs manquants : ' + (miss.length ? miss.join(', ') : 'aucun');
        var recapEl = document.getElementById('w-recap'); if (recapEl) recapEl.textContent = buildRecap();
      }
      form.addEventListener('input', update);
      update();
      var rc = document.querySelector('[data-recap-copy]'); if (rc) rc.addEventListener('click', function () { copyText(buildRecap(), rc); });
      var ac = document.querySelector('[data-art-copy]'); if (ac) ac.addEventListener('click', function () { copyText(buildBlock(), ac); });
    })();

    // --- Fiche œuvre + preuve de création (organise + prépare, NE SAUVEGARDE PAS) ---
    (function () {
      var form = document.getElementById('p-form');
      if (!form) return;
      function v(id) { var el = document.getElementById(id); return el ? el.value.trim() : ''; }
      function c(id) { var el = document.getElementById(id); return !!(el && el.checked); }
      function set(id, val) { var el = document.getElementById(id); if (el && val) el.value = val; }
      var statusFr = { available: 'Disponible', reserved: 'Réservée', sold: 'Vendue', 'on-request': 'Sur demande' };

      // Pré-remplir depuis une œuvre existante.
      var pick = document.getElementById('p-pick');
      if (pick) {
        pick.addEventListener('change', function () {
          var opt = pick.options[pick.selectedIndex];
          if (!opt || !opt.value) return;
          set('p-title', opt.getAttribute('data-title'));
          set('p-series', opt.getAttribute('data-series'));
          set('p-year', opt.getAttribute('data-year'));
          set('p-dimensions', opt.getAttribute('data-dimensions'));
          set('p-technique', opt.getAttribute('data-technique'));
          set('p-description', opt.getAttribute('data-description'));
          set('p-alt', opt.getAttribute('data-alt'));
          set('p-web', opt.getAttribute('data-image'));
          var st = document.getElementById('p-status');
          if (st && opt.getAttribute('data-status')) st.value = opt.getAttribute('data-status');
          update();
        });
      }

      function price() { return v('p-price') || 'Prix sur demande'; }
      function buildFiche() {
        return [
          'FICHE ŒUVRE — PREUVE DE CRÉATION',
          '',
          'Titre : ' + v('p-title'),
          'Série : ' + v('p-series'),
          'Année : ' + v('p-year'),
          'Dimensions : ' + v('p-dimensions'),
          'Technique : ' + v('p-technique'),
          'Support : ' + v('p-support'),
          'Description : ' + v('p-description'),
          'Date de création : ' + v('p-date'),
          'Lieu de création : ' + v('p-place'),
          'Images conservées :',
          '- HD originale : ' + v('p-hd'),
          '- Version web : ' + v('p-web'),
          '- Détails : ' + v('p-details'),
          'Statut : ' + (statusFr[v('p-status')] || v('p-status')),
          'Prix : ' + price(),
          'Publication web : ' + v('p-webpub'),
          'Alt text : ' + v('p-alt'),
          'Notes de protection : ' + v('p-protect'),
          'Historique d’exposition : ' + v('p-history'),
          'Demande / acquéreur : ' + v('p-request'),
          'Remise / logistique : ' + v('p-logistics'),
          'Réseaux sociaux : ' + v('p-social'),
          'Hashtags : ' + v('p-hashtags'),
          'Validation humaine : à vérifier avant publication',
        ].join('\n');
      }
      function buildChecklist() {
        var items = ['CHECKLIST DE PROTECTION — avant diffusion', ''];
        document.querySelectorAll('#p-checklist li span').forEach(function (el) {
          items.push('[ ] ' + el.textContent);
        });
        return items.join('\n');
      }

      var keys = ['p-title', 'p-series', 'p-year', 'p-dimensions', 'p-technique', 'p-support', 'p-description', 'p-date', 'p-place', 'p-hd', 'p-web', 'p-details', 'p-alt', 'p-webpub', 'p-protect', 'p-history', 'p-social', 'p-hashtags'];
      var checks = ['p-hd-kept', 'p-web-ready', 'p-proof-kept', 'p-exchanges', 'p-saleok'];
      function update() {
        var filled = 1, total = keys.length + checks.length + 1; // statut + prix par défaut
        keys.forEach(function (k) { if (v(k)) filled++; });
        checks.forEach(function (k) { if (c(k)) filled++; });
        var score = Math.round((filled / total) * 100);
        var bar = document.getElementById('p-bar'); if (bar) bar.style.width = score + '%';
        var sc = document.getElementById('p-score'); if (sc) sc.textContent = String(score);
        var lvl = document.getElementById('p-level');
        if (lvl) lvl.textContent = score >= 80 ? 'Prêt à valider' : (score >= 40 ? 'Presque prêt' : 'Brouillon');
        var got = {
          fiche: !!(v('p-title') && v('p-dimensions') && v('p-technique') && v('p-description')),
          images: !!(v('p-web') && v('p-alt') && c('p-web-ready')),
          protection: !!(v('p-date') && (c('p-proof-kept') || c('p-hd-kept'))),
          web: !!(v('p-webpub') && v('p-alt')),
          social: !!(v('p-social') && v('p-hashtags')),
          sale: c('p-saleok'),
        };
        document.querySelectorAll('[data-pbadge]').forEach(function (el) {
          var on = got[el.getAttribute('data-pbadge')];
          el.className = 'rounded-full px-3 py-1 text-xs ' + (on ? 'border border-or/60 bg-or/10 text-encre' : 'border border-cendre/30 text-cendre');
        });
        var recapEl = document.getElementById('p-recap'); if (recapEl) recapEl.textContent = buildFiche();
      }
      form.addEventListener('input', update);
      update();
      var fc = document.querySelector('[data-fiche-copy]'); if (fc) fc.addEventListener('click', function () { copyText(buildFiche(), fc); });
      var cc = document.querySelector('[data-checklist-copy]'); if (cc) cc.addEventListener('click', function () { copyText(buildChecklist(), cc); });
    })();
  </script>
</Base>
