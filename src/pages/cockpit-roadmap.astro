---
import Base from '../layouts/Base.astro';
import ArtworkPlaceholder from '../components/ArtworkPlaceholder.astro';
import { artworks, statusLabel, isForSale, hasImage, type ArtworkStatus } from '../data/artworks';
import { shop } from '../data/shop';
import { socialPublishing } from '../data/social';
import { cockpit } from '../data/cockpit';
import { theme } from '../data/theme';
import { splitExhibitions } from '../data/exhibitions';
import { operations, operationsPrinciple, type OperationStatus } from '../data/operations';
import { artworkWorkflow, workflowBadges } from '../data/artworkWorkflow';
import { designModes } from '../data/theme';
import { artworkProof, webPublicationTips, protectionChecklist, proofBadges } from '../data/proof';

// ---- Données (lecture seule) ----
const totalArtworks = artworks.length;
const withImage = artworks.filter(hasImage).length;
const statuses: ArtworkStatus[] = ['available', 'reserved', 'sold', 'on-request'];
const byStatus = Object.fromEntries(
  statuses.map((s) => [s, artworks.filter((a) => a.status === s)]),
) as Record<ArtworkStatus, typeof artworks>;
const { upcoming, past } = splitExhibitions();

// Champs requis pour ajouter une œuvre (depuis le schéma cockpit).

// Zones éditoriales pilotables et où elles vivent aujourd'hui.
const editorialZones = [
  { label: 'Accueil (accroche + récit)', file: 'src/content/pages.ts · src/data/site.ts' },
  { label: 'Biographie', file: 'src/content/bio.ts' },
  { label: 'Démarche', file: 'src/content/bio.ts' },
  { label: 'Bleu Cendres', file: 'src/content/bio.ts' },
  { label: 'Expositions', file: 'src/data/exhibitions.ts' },
  { label: 'Contact (e-mail, sujets)', file: 'src/data/site.ts · src/data/shop.ts' },
];

// Palette actuelle (depuis theme.ts) pour l'aperçu « Ambiance visuelle ».
const palette = [
  { key: 'paper', label: 'Papier (fond)', hex: theme.colors.paper },
  { key: 'paperRaw', label: 'Papier brut', hex: theme.colors.paperRaw },
  { key: 'bluePigment', label: 'Bleu pigment', hex: theme.colors.bluePigment },
  { key: 'blueDeep', label: 'Bleu nuit', hex: theme.colors.blueDeep },
  { key: 'blueWash', label: 'Bleu aquatique', hex: theme.colors.blueWash },
  { key: 'ochreGold', label: 'Ocre / or', hex: theme.colors.ochreGold },
  { key: 'inkBlack', label: 'Noir encre', hex: theme.colors.inkBlack },
  { key: 'ashBlue', label: 'Cendre', hex: theme.colors.ashBlue },
];

const sections = [
  { id: 'apercu', label: 'Vue d’ensemble' },
  { id: 'operations', label: 'Centre opérationnel' },
  { id: 'oeuvres', label: 'Œuvres' },
  { id: 'intake', label: 'Ajouter une œuvre' },
  { id: 'proof', label: 'Fiche œuvre + preuve' },
  { id: 'disponibilites', label: 'Disponibilités' },
  { id: 'pages', label: 'Pages' },
  { id: 'expositions', label: 'Expositions' },
  { id: 'social', label: 'Réseaux sociaux' },
  { id: 'ambiance', label: 'Ambiance visuelle' },
  { id: 'etapes', label: 'Prochaines étapes' },
];

// Titres orientés action pour les cartes du centre opérationnel.
const opCardTitle: Record<string, string> = {
  ip: 'Protéger une œuvre',
  social: 'Préparer une publication',
  'soft-sale': 'Répondre à une demande',
  invoicing: 'Préparer une facture brouillon',
  logistics: 'Organiser la remise ou livraison',
  catalog: 'Préparer un catalogue',
};
const opStatusLabel: Record<OperationStatus, string> = {
  planned: 'à venir',
  prototype: 'prototype',
  active: 'actif',
};
const opStatusColor: Record<OperationStatus, string> = {
  planned: 'text-cendre',
  prototype: 'text-or',
  active: 'text-encre',
};
const opCards = operations.filter((o) => o.id !== 'human-relation');

const statusChipClass: Record<ArtworkStatus, string> = {
  available: 'text-encre',
  reserved: 'text-or',
  sold: 'text-cendre',
  'on-request': 'text-cendre',
};
---
<Base
  title="Cockpit artiste — prototype"
  description="Cockpit prototype (lecture / préparation) — outil interne, non public."
  noindex={true}
>
  <section class="shell pb-section pt-10 sm:pt-14">
    <p class="eyebrow mb-3">Outil interne · non public</p>
    <h1 class="signature text-display text-encre">Cockpit artiste — prototype</h1>

    <p class="mt-5 max-w-prose rounded-card border border-or/40 bg-or/5 px-5 py-4 text-noir/80">
      <strong>Prototype.</strong> Cet espace montre ce qu’Armelle pourra piloter elle-même.
      Il <strong>ne sauvegarde rien</strong> pour l’instant : on visualise et on prépare les
      contenus. Aucune connexion, aucun mot de passe, aucun paiement.
    </p>

    <!-- Sommaire -->
    <nav aria-label="Sections du cockpit" class="mt-8 flex flex-wrap gap-x-5 gap-y-2 text-sm">
      {sections.map((s) => (
        <a href={`#${s.id}`} class="link-quiet font-semibold">{s.label}</a>
      ))}
    </nav>

    <!-- 1 — VUE D'ENSEMBLE -->
    <section id="apercu" class="scroll-mt-28">
      <h2 class="mt-14 text-h2 font-serif text-encre">Vue d’ensemble</h2>
      <div class="rule-gold mt-4" aria-hidden="true"></div>
      <p class="mt-4 max-w-prose font-serif text-lg italic text-encre">{cockpit.philosophy}</p>
      <dl class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-4">
        <div class="frame-gallery p-4"><dt class="text-eyebrow uppercase tracking-[0.16em] text-cendre">Œuvres</dt><dd class="mt-1 font-serif text-3xl text-encre">{totalArtworks}</dd></div>
        <div class="frame-gallery p-4"><dt class="text-eyebrow uppercase tracking-[0.16em] text-cendre">Disponibles</dt><dd class="mt-1 font-serif text-3xl text-encre">{artworks.filter(isForSale).length}</dd></div>
        <div class="frame-gallery p-4"><dt class="text-eyebrow uppercase tracking-[0.16em] text-cendre">Avec photo</dt><dd class="mt-1 font-serif text-3xl text-encre">{withImage}/{totalArtworks}</dd></div>
        <div class="frame-gallery p-4"><dt class="text-eyebrow uppercase tracking-[0.16em] text-cendre">Expositions</dt><dd class="mt-1 font-serif text-3xl text-encre">{upcoming.length + past.length}</dd></div>
      </dl>
      <ul class="mt-6 grid gap-2 sm:grid-cols-2">
        {cockpit.modules.map((m) => (
          <li class="border-l-2 border-cendre/30 pl-4">
            <span class="text-encre">{m.label}</span>
            <span class="block text-sm text-cendre">{m.description}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- CENTRE OPÉRATIONNEL -->
    <section id="operations" class="scroll-mt-28">
      <h2 class="mt-16 text-h2 font-serif text-encre">Centre opérationnel</h2>
      <div class="rule-gold mt-4" aria-hidden="true"></div>
      <p class="mt-4 max-w-prose text-noir/80">
        Le cockpit simplifie le quotidien : <strong>préparer, organiser, protéger</strong> —
        pour qu’Armelle se concentre sur son art. Certaines fonctions sont <em>futures</em>.
      </p>
      <p class="mt-2 max-w-prose text-sm italic text-cendre">{operationsPrinciple}</p>

      <div class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {opCards.map((o) => (
          <article class="frame-gallery p-5">
            <div class="flex items-baseline justify-between gap-3">
              <h3 class="font-serif text-lg italic text-encre">{opCardTitle[o.id] ?? o.label}</h3>
              <span class={`text-eyebrow uppercase tracking-[0.14em] ${opStatusColor[o.status]}`}>{opStatusLabel[o.status]}</span>
            </div>
            <p class="mt-2 text-sm text-noir/75">{o.description}</p>
            <ul class="mt-2 space-y-0.5 text-sm text-noir/70">
              {o.actions.slice(0, 3).map((a) => <li>· {a}</li>)}
            </ul>
          </article>
        ))}
      </div>

      <p class="mt-6 max-w-prose rounded-card border border-cendre/30 bg-brume/40 px-5 py-4 text-sm text-noir/80">
        <strong>Aucune action sensible ne sera automatisée sans validation humaine.</strong>
        Armelle décide · Tom valide · Claude Code exécute. L’objectif est de laisser l’artiste
        se concentrer sur son art. Voir aussi <code class="text-cendre">docs/ip-protection-artist.md</code>.
      </p>
    </section>

    <!-- 2 — ŒUVRES -->
    <section id="oeuvres" class="scroll-mt-28">
      <h2 class="mt-16 text-h2 font-serif text-encre">Œuvres</h2>
      <div class="rule-gold mt-4" aria-hidden="true"></div>
      <p class="mt-4 text-noir/75">{totalArtworks} œuvres au catalogue · source : <code class="text-cendre">src/data/artworks.ts</code></p>

      <ul class="mt-6 divide-y divide-cendre/20 border-y border-cendre/20">
        {artworks.map((a) => (
          <li class="flex items-center gap-4 py-3">
            <span class="h-12 w-10 shrink-0 overflow-hidden border border-cendre/25">
              {a.image ? (
                <img src={a.image} alt={a.alt} class="h-full w-full object-cover" loading="lazy" width="40" height="48" />
              ) : (
                <ArtworkPlaceholder />
              )}
            </span>
            <span class="min-w-0 flex-1">
              <span class="block truncate font-serif italic text-encre">{a.title}</span>
              <span class="block truncate text-xs text-cendre">{[a.series, a.technique].filter(Boolean).join(' · ')}</span>
            </span>
            <span class={`shrink-0 text-[0.7rem] uppercase tracking-[0.16em] ${statusChipClass[a.status]}`}>{statusLabel[a.status]}</span>
            <span class={`hidden shrink-0 text-xs sm:inline ${hasImage(a) ? 'text-encre' : 'text-cendre'}`}>{hasImage(a) ? 'photo presente' : 'photo a venir'}</span>
          </li>
        ))}
      </ul>

      <p class="mt-10 max-w-prose text-noir/75">
        Pour saisir une œuvre pas à pas — avec un <strong>garde-fou avant publication</strong> —
        utilisez l’<a href="#intake" class="link-quiet font-semibold">assistant « Ajouter une œuvre »</a> ci-dessous.
      </p>
    </section>

    <!-- ASSISTANT « AJOUTER UNE ŒUVRE » (prototype, ne sauvegarde pas) -->
    <section id="intake" class="scroll-mt-28">
      <h2 class="mt-16 text-h2 font-serif text-encre">Ajouter une œuvre — assistant prototype</h2>
      <div class="rule-gold mt-4" aria-hidden="true"></div>
      <p class="mt-4 max-w-prose text-noir/80">
        On prépare la fiche pas à pas, on vérifie, on copie le récapitulatif.
        <strong>Rien n’est sauvegardé ni publié ici</strong> : aucune base de données, aucun envoi.
        La publication se fait ensuite, <em>à valider humainement</em>.
      </p>

      <!-- Étapes du parcours -->
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {artworkWorkflow.map((s, i) => (
          <article class="frame-gallery p-4">
            <p class="text-eyebrow uppercase tracking-[0.16em] text-cendre">{String(i + 1).padStart(2, '0')}</p>
            <h3 class="mt-1 font-serif text-lg italic text-encre">{s.label}</h3>
            <p class="mt-1 text-sm text-noir/75">{s.description}</p>
            <p class="mt-2 text-xs text-cendre">À préparer : {s.requiredFields.join(' · ')}</p>
          </article>
        ))}
      </div>

      <!-- Préparation de la fiche (NE SAUVEGARDE PAS) -->
      <h3 class="mt-10 text-h3 font-serif text-encre">Préparer la fiche</h3>
      <form id="w-form" class="mt-5 grid max-w-3xl gap-4 frame-gallery p-5 sm:grid-cols-2" onsubmit="return false">
        <label class="text-sm">Titre
          <input id="w-title" type="text" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none" />
        </label>
        <label class="text-sm">Série <span class="text-cendre">(optionnel)</span>
          <input id="w-series" type="text" placeholder="Bleu Cendres" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none" />
        </label>
        <label class="text-sm">Année <span class="text-cendre">(sinon vide)</span>
          <input id="w-year" type="text" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none" />
        </label>
        <label class="text-sm">Statut
          <select id="w-status" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none">
            <option value="available">Disponible</option>
            <option value="reserved">Réservée</option>
            <option value="sold">Vendue</option>
            <option value="on-request">Sur demande</option>
          </select>
        </label>
        <label class="text-sm">Dimensions <span class="text-cendre">(ne pas inventer)</span>
          <input id="w-dimensions" type="text" placeholder="60 × 73 cm" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none" />
        </label>
        <label class="text-sm">Technique
          <input id="w-technique" type="text" placeholder="Acrylique sur toile" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none" />
        </label>
        <label class="text-sm">Support
          <input id="w-support" type="text" placeholder="Toile recyclée" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none" />
        </label>
        <label class="text-sm">Mots-clés / ambiance
          <input id="w-keywords" type="text" placeholder="bleu, or, matière" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none" />
        </label>
        <label class="text-sm sm:col-span-2">Description (quelques mots)
          <textarea id="w-description" rows="2" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none"></textarea>
        </label>
        <label class="text-sm">Photo principale (nom de fichier)
          <input id="w-image" type="text" placeholder="/images/artworks/mon-oeuvre.webp" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none" />
        </label>
        <label class="text-sm">Photos de détail <span class="text-cendre">(optionnel)</span>
          <input id="w-detail" type="text" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none" />
        </label>
        <label class="text-sm sm:col-span-2">Alt text (décrire vraiment l’œuvre)
          <input id="w-alt" type="text" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none" />
        </label>
        <label class="text-sm">Prix <span class="text-cendre">(vide = « Prix sur demande »)</span>
          <input id="w-price" type="text" placeholder="laisser vide" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none" />
        </label>
        <label class="text-sm">Date de création
          <input id="w-date" type="text" placeholder="AAAA-MM-JJ" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none" />
        </label>
        <label class="text-sm sm:col-span-2">Légende Instagram (brouillon)
          <textarea id="w-caption" rows="2" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none"></textarea>
        </label>
        <label class="text-sm sm:col-span-2">Hashtags
          <input id="w-hashtags" type="text" placeholder="#ArmelleMourier #BleuCendres" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none" />
        </label>
        <fieldset class="sm:col-span-2 mt-1 space-y-2 text-sm">
          <label class="flex items-center gap-2"><input id="w-web" type="checkbox" /> Version web compressée prête</label>
          <label class="flex items-center gap-2"><input id="w-hd" type="checkbox" /> HD originale conservée hors du site (privée)</label>
          <label class="flex items-center gap-2"><input id="w-proof" type="checkbox" /> Œuvre importante : preuve de création prévue (e-Soleau)</label>
          <label class="flex items-center gap-2"><input id="w-saleok" type="checkbox" /> Vente douce vérifiée — « Prix sur demande » si rien n’est validé</label>
        </fieldset>
      </form>

      <!-- Gamification douce -->
      <div class="mt-6 frame-gallery p-5">
        <div class="flex flex-wrap items-baseline justify-between gap-3">
          <p class="text-eyebrow uppercase tracking-[0.16em] text-cendre">Niveau de préparation</p>
          <p id="w-level" class="font-serif italic text-encre">Brouillon</p>
        </div>
        <div class="mt-3 h-2 w-full overflow-hidden rounded-full bg-brume">
          <div id="w-bar" class="h-full bg-or transition-all" style="width:0%"></div>
        </div>
        <p class="mt-2 text-sm text-cendre"><span id="w-score">0</span> % de complétude — indicatif, pas une note.</p>
        <ul id="w-badges" class="mt-4 flex flex-wrap gap-2">
          {workflowBadges.map((b) => (
            <li data-badge={b.id} class="rounded-full border border-cendre/30 px-3 py-1 text-xs text-cendre">{b.label}</li>
          ))}
        </ul>
      </div>

      <!-- Garde-fou : avant de publier -->
      <h3 class="mt-10 text-h3 font-serif text-encre">Avant de publier cette œuvre, vérifier :</h3>
      <ul class="mt-4 grid max-w-3xl gap-2 text-sm sm:grid-cols-2">
        {[
          'Le titre est correct.',
          'La série est correcte.',
          'Les dimensions sont renseignées.',
          'La technique est renseignée.',
          'Le statut est correct.',
          'L’image principale existe.',
          'L’alt text décrit vraiment l’œuvre.',
          'La HD originale est conservée hors site.',
          'La version web est compressée.',
          'L’œuvre importante est documentée (preuve de création).',
          'Le prix n’est pas inventé.',
          'La vente reste « Prix sur demande » si rien n’est validé.',
        ].map((item) => (
          <li class="flex items-start gap-2"><input type="checkbox" class="mt-0.5" /><span class="text-noir/80">{item}</span></li>
        ))}
      </ul>

      <!-- Récapitulatif copiable -->
      <h3 class="mt-10 text-h3 font-serif text-encre">Récapitulatif avant publication</h3>
      <p class="mt-2 text-sm text-cendre" id="w-missing">Champs manquants : —</p>
      <pre id="w-recap" class="mt-3 max-w-3xl overflow-x-auto whitespace-pre-wrap rounded-card border border-cendre/30 bg-brume/40 p-4 text-sm text-noir/85"></pre>
      <div class="mt-4 flex flex-wrap gap-3">
        <button type="button" class="btn btn-primary" data-recap-copy>Copier le récapitulatif</button>
        <button type="button" class="btn btn-ghost" data-art-copy>Copier le bloc artworks.ts</button>
      </div>
      <p class="mt-3 max-w-prose text-sm italic text-or">
        À valider humainement. Rien n’est publié automatiquement : Armelle décide, Tom valide.
      </p>
    </section>

    <!-- FICHE ŒUVRE + PREUVE DE CRÉATION (prototype, ne sauvegarde pas) -->
    <section id="proof" class="scroll-mt-28">
      <h2 class="mt-16 text-h2 font-serif text-encre">{artworkProof.title}</h2>
      <div class="rule-gold mt-4" aria-hidden="true"></div>
      <p class="mt-4 max-w-prose text-noir/80">{artworkProof.intro}</p>

      <!-- Avertissement non juridique -->
      <p class="mt-5 max-w-prose rounded-card border border-or/40 bg-or/5 px-5 py-4 text-sm text-noir/80">
        ⚠️ {artworkProof.disclaimer}
      </p>

      <!-- Repères de propriété intellectuelle -->
      <h3 class="mt-8 text-h3 font-serif text-encre">Ce qu’il faut savoir (repères)</h3>
      <ul class="mt-4 max-w-prose space-y-2 text-sm text-noir/80">
        {artworkProof.legalPoints.map((p) => (
          <li class="flex items-start gap-2"><span class="mt-1 text-or" aria-hidden="true">·</span><span>{p}</span></li>
        ))}
      </ul>

      <!-- Parties de la fiche -->
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {artworkProof.sections.map((s, i) => (
          <article class="frame-gallery p-4">
            <p class="text-eyebrow uppercase tracking-[0.16em] text-cendre">{String(i + 1).padStart(2, '0')}</p>
            <h4 class="mt-1 font-serif text-lg italic text-encre">{s.label}</h4>
            {s.note && <p class="mt-1 text-sm text-noir/70">{s.note}</p>}
            <p class="mt-2 text-xs text-cendre">{s.fields.join(' · ')}</p>
          </article>
        ))}
      </div>

      <!-- Générer une fiche œuvre -->
      <h3 class="mt-10 text-h3 font-serif text-encre">Générer une fiche œuvre</h3>
      <p class="mt-2 max-w-prose text-sm text-cendre">
        Choisissez une œuvre existante pour pré-remplir, ou partez du modèle vide.
        <strong>Rien n’est sauvegardé ni téléversé</strong> — on prépare un dossier texte à copier.
      </p>

      <label class="mt-4 block max-w-md text-sm">Pré-remplir depuis une œuvre existante
        <select id="p-pick" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none">
          <option value="">— Modèle vide —</option>
          {artworks.map((a) => (
            <option
              value={a.slug}
              data-title={a.title}
              data-series={a.series ?? ''}
              data-year={a.year ?? ''}
              data-dimensions={a.dimensions ?? ''}
              data-technique={a.technique ?? ''}
              data-description={a.description ?? ''}
              data-status={a.status}
              data-statuslabel={statusLabel[a.status]}
              data-alt={a.alt}
              data-image={a.image ?? ''}
            >{a.title}</option>
          ))}
        </select>
      </label>

      <form id="p-form" class="mt-5 grid max-w-3xl gap-4 frame-gallery p-5 sm:grid-cols-2" onsubmit="return false">
        <p class="sm:col-span-2 text-eyebrow uppercase tracking-[0.16em] text-cendre">Identité & description</p>
        <label class="text-sm">Titre
          <input id="p-title" type="text" class="mt-1 w-full rounded-sm border border-cendre/35 bg-paper px-3 py-2 text-noir focus:border-or focus:outline-none" />
        </label>
        <label class="text-sm">Série <span class="text-cendre">(optionnel)</span>
