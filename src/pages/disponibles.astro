---
import Base from '../layouts/Base.astro';
import SectionTitle from '../components/SectionTitle.astro';
import ArtworkGrid from '../components/ArtworkGrid.astro';
import Trait from '../components/Trait.astro';
import { availableArtworks } from '../data/artworks';
import { site } from '../data/site';
import { shop } from '../data/shop';

// Œuvres présentables à l'acquisition (centralisé dans artworks.ts :
// respecte le statut et le drapeau showInAvailable).
const forSale = availableArtworks;
const hasFilter = new Set(forSale.map((a) => a.series).filter(Boolean)).size > 1;
---
<Base
  title={`Tableaux disponibles — ${site.artistName}`}
  description="Œuvres originales d’Armelle Mourier disponibles à l’acquisition. Une galerie privée, sobre et humaine : prix sur demande, réservation et catalogue par contact direct avec l’artiste."
  keywords={['acheter tableau artiste peintre', 'œuvre originale artiste française', 'tableaux contemporains', 'Armelle Mourier', 'acquisition tableau']}
>
  <!-- INTRO « galerie privée » -->
  <section class="shell pb-section pt-12 sm:pt-16">
    <p class="eyebrow reveal is-visible mb-3">Sélection d’atelier</p>
    <h1 class="reveal is-visible text-h1 font-serif text-encre">Tableaux disponibles</h1>
    <Trait class="reveal is-visible mt-5 text-or" width="7rem" />
    <p class="reveal mt-7 max-w-prose font-serif text-xl italic leading-snug text-encre">
      Acquisition en lien direct avec l’artiste — prix sur demande.
    </p>
    <p class="reveal mt-5 max-w-prose text-lg leading-relaxed text-noir/85">
      Quelques œuvres quittent l’atelier. Pour connaître les conditions, réserver une toile ou
      recevoir les informations, écrivez simplement à l’artiste.
    </p>
    <p class="reveal mt-4 max-w-prose text-noir/70">
      Ce n’est pas une boutique automatique. Chaque toile est une pièce unique&nbsp;: pas de panier
      ni de paiement en ligne, simplement une conversation — le temps de répondre à vos questions
      sur le format, la technique ou l’encadrement, de réserver une œuvre ou de recevoir le catalogue.
    </p>
  </section>

  <!-- GRILLE DES ŒUVRES DISPONIBLES -->
  <section class="bg-brume py-section">
    <div class="shell">
      <SectionTitle eyebrow="À acquérir" title="Les œuvres proposées" />
      {forSale.length > 0 ? (
        <div class="mt-12">
          <ArtworkGrid artworks={forSale} filterable={hasFilter} />
        </div>
      ) : (
        <p class="mt-10 max-w-prose text-noir/75">
          Aucune œuvre n’est proposée à l’acquisition pour le moment. N’hésitez pas à écrire à
          l’artiste pour être informé·e des prochaines disponibilités.
        </p>
      )}
    </div>
  </section>

  <!-- COMMENT ACQUÉRIR -->
  <section class="shell py-section">
    <SectionTitle eyebrow="En pratique" title="Acquérir une œuvre" />
    <div class="mt-10 grid gap-8 sm:grid-cols-3">
      <div class="reveal">
        <span class="font-serif text-3xl text-or">01</span>
        <h3 class="mt-2 text-h3 font-serif text-encre">Choisir une œuvre</h3>
        <p class="mt-2 text-noir/75">
          Parcourez la sélection, ouvrez la fiche d’une œuvre pour voir le format, la technique
          et la série. Chaque toile est une pièce unique.
        </p>
      </div>
      <div class="reveal">
        <span class="font-serif text-3xl text-or">02</span>
        <h3 class="mt-2 text-h3 font-serif text-encre">Écrire à l’artiste</h3>
        <p class="mt-2 text-noir/75">
          Cliquez sur «&nbsp;Demander cette œuvre&nbsp;»&nbsp;: le titre est repris
          automatiquement. Vous pouvez aussi simplement réserver ou poser vos questions.
        </p>
      </div>
      <div class="reveal">
        <span class="font-serif text-3xl text-or">03</span>
        <h3 class="mt-2 text-h3 font-serif text-encre">Recevoir les informations</h3>
        <p class="mt-2 text-noir/75">
          Prix, disponibilité, dimensions exactes, encadrement, remise en main propre dans la
          région de Dijon ou expédition soignée&nbsp;: tout se précise dans l’échange.
        </p>
      </div>
    </div>

    <div class="mt-12 flex flex-wrap gap-x-8 gap-y-4">
      <a href="/contact?objet=acquisition" class="btn-primary">Demander une œuvre</a>
      {shop.enableReservation && (
        <a href="/contact?objet=reservation" class="btn-ghost">{shop.cta.reserve}</a>
      )}
      {shop.enableCatalogRequest && (
        <a href="/contact?objet=catalogue" class="btn-gold">{shop.cta.catalog}</a>
      )}
    </div>
  </section>
</Base>
